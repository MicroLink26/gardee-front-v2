---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
import PostulerForm from '../components/vue/PostulerForm.vue';
---
<BaseLayout
  title="Devenir prestataire"
  description="Rejoignez Gardee et proposez vos services de jardinage à des particuliers près de chez vous."
>
  <Navbar />
  <main class="page-main">
    <PostulerForm client:load />
  </main>
  <Footer />
</BaseLayout>

<style>
.page-main { padding: 3rem 0; min-height: 60vh; background: #f9fafb; }
</style>
