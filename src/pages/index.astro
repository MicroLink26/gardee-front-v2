---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
---
<BaseLayout
  title="Trouvez votre jardinier"
  description="Gardee connecte les particuliers avec des jardiniers professionnels vérifiés. Tonte, taille, élagage, paysagisme."
>
  <Navbar />

  <!-- ══ HERO ═══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-left">
      <span class="hero-badge">✦ Plateforme certifiée</span>
      <h1>Votre jardin mérite<br>le <em>meilleur</em></h1>
      <p class="hero-sub">Des jardiniers professionnels vérifiés, près de chez vous.</p>

      <form class="search-bar" action="/classement" method="get">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input name="q" type="search" placeholder="Tonte, taille, élagage…" autocomplete="off" />
        <button type="submit">Rechercher</button>
      </form>

      <div class="search-pills">
        <span class="pills-label">Populaire :</span>
        <a href="/classement?q=tonte" class="pill">Tonte</a>
        <a href="/classement?q=taille" class="pill">Taille de haies</a>
        <a href="/classement?q=élagage" class="pill">Élagage</a>
        <a href="/classement?q=paysagisme" class="pill">Paysagisme</a>
      </div>

      <div class="hero-ctas">
        <a href="/carte" class="cta-map">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
          Voir la carte
        </a>
        <a href="/postuler" class="cta-link">Vous êtes jardinier ? →</a>
      </div>
    </div>

    <div class="hero-right">
      <img src="/pommier.png" alt="Jardinage" class="hero-illus" />
    </div>
  </section>

  <!-- ══ CHIFFRES CLÉS ══════════════════════════════════════════════ -->
  <div class="trust-strip">
    <div class="trust-item">
      <strong>500<span>+</span></strong>
      <span>jardiniers vérifiés</span>
    </div>
    <div class="trust-sep"></div>
    <div class="trust-item">
      <strong>4,8<span>★</span></strong>
      <span>note moyenne</span>
    </div>
    <div class="trust-sep"></div>
    <div class="trust-item">
      <strong>12 000<span>+</span></strong>
      <span>jardins entretenus</span>
    </div>
  </div>

  <!-- ══ NOS SERVICES ═══════════════════════════════════════════════ -->
  <section class="services-section">
    <div class="container">
      <p class="eyebrow">NOS SERVICES</p>
      <h2 class="section-title">Une plateforme,<br>deux façons d'en profiter</h2>
      <div class="services-grid">

        <div class="svc-card">
          <div class="svc-illus">
            <img src="/futur-left.png" alt="Détenteurs de jardins" />
          </div>
          <div class="svc-text">
            <div class="svc-tag">Pour les propriétaires</div>
            <h3>Sublimez votre jardin</h3>
            <p>Choisissez parmi les meilleurs jardiniers, paysagistes, élagueurs ou piscinistes de votre région. Comparez les avis, les tarifs, et réservez en quelques clics.</p>
            <div class="svc-services">
              <span>Tonte</span><span>Taille</span><span>Élagage</span><span>Paysagisme</span>
            </div>
            <a href="/carte" class="svc-cta">Trouver un jardinier →</a>
          </div>
        </div>

        <div class="svc-card svc-card--reverse">
          <div class="svc-illus">
            <img src="/futur-right.png" alt="Pour les jardiniers" />
          </div>
          <div class="svc-text">
            <div class="svc-tag svc-tag--green">Pour les professionnels</div>
            <h3>Développez votre activité</h3>
            <p>Rejoignez Gardee et gagnez en visibilité locale. Collectez des avis vérifiés, montez dans le classement et remplissez votre carnet de commandes.</p>
            <div class="svc-services">
              <span>Visibilité</span><span>Avis vérifiés</span><span>Réservations</span>
            </div>
            <a href="/postuler" class="svc-cta">Postuler →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ COMMENT ÇA MARCHE ══════════════════════════════════════════ -->
  <section class="how-section">
    <div class="container">
      <p class="eyebrow eyebrow--dark">COMMENT ÇA MARCHE</p>
      <h2 class="section-title">Simple comme bonjour</h2>
      <div class="how-grid">

        <div class="how-step">
          <span class="how-num">01</span>
          <div class="how-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h4>Décrivez vos besoins</h4>
          <p>Entrez le service recherché et votre localisation pour voir les jardiniers disponibles près de chez vous.</p>
        </div>

        <div class="how-step">
          <span class="how-num">02</span>
          <div class="how-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h4>Choisissez votre jardinier</h4>
          <p>Consultez les profils, les avis clients et les tarifs. Comparez et sélectionnez le professionnel qui vous convient.</p>
        </div>

        <div class="how-step">
          <span class="how-num">03</span>
          <div class="how-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h4>Profitez de votre jardin</h4>
          <p>Réservez directement en ligne. Votre jardinier intervient au créneau choisi. Laissez un avis pour la communauté.</p>
        </div>

      </div>
    </div>
    <div class="how-illus">
      <img src="/tondeuse.png" alt="" aria-hidden="true" />
    </div>
  </section>

  <!-- ══ FAQ — arbres pictos ════════════════════════════════════════ -->
  <section class="faq-section">
    <div class="faq-header">
      <p class="eyebrow eyebrow--light">VOS QUESTIONS</p>
      <h2>Tout ce que vous voulez savoir</h2>
    </div>

    <div class="trees-row">
      <a href="/contact" class="tree-item" data-answer="Utilisez la carte ou la barre de recherche pour trouver un jardinier. Consultez son profil, ses avis, et réservez un créneau directement sur la plateforme.">
        <p class="tree-label">Comment utiliser ?</p>
        <img src="/arbreUtiliser.png" alt="Comment utiliser Gardee ?" />
      </a>
      <a href="/postuler" class="tree-item" data-answer="Gardee vous offre une visibilité locale, des avis vérifiés qui valorisent votre expertise, et une interface simple pour gérer vos réservations.">
        <p class="tree-label">Pourquoi postuler ?</p>
        <img src="/arbrePostuler.png" alt="Pourquoi postuler sur Gardee ?" />
      </a>
      <a href="/contact" class="tree-item" data-answer="Notre équipe est disponible via la page contact. Vous pouvez aussi nous écrire à contact@gardee.fr pour toute question.">
        <p class="tree-label">Nous contacter</p>
        <img src="/arbreContacter.png" alt="Qui contacter ?" />
      </a>
      <a href="/contact" class="tree-item" data-answer="Nous développons une messagerie sécurisée, un paiement en ligne, et un calendrier en temps réel. L'objectif : gérer tout votre parcours sans quitter Gardee.">
        <p class="tree-label">Notre vision</p>
        <img src="/arbreBut.png" alt="Quel but sur le long terme ?" />
      </a>
    </div>

    <div class="faq-answer" id="faqAnswer"></div>

    <div class="faq-ground">
      <img src="/bg-faq.png" alt="" aria-hidden="true" />
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

/* ══ HERO ════════════════════════════════════════════════════════ */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: calc(100vh - 56px);
  background: #14231a;
}

.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 5rem 4rem 5rem 5rem;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #a8c47a;
  background: rgba(168, 196, 122, 0.12);
  border: 1px solid rgba(168, 196, 122, 0.3);
  border-radius: 100px;
  padding: 0.35rem 0.9rem;
  width: fit-content;
  margin-bottom: 1.75rem;
}

.hero-left h1 {
  font-size: clamp(2.6rem, 4.5vw, 4.2rem);
  font-weight: 900;
  line-height: 1.06;
  color: #fff;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
}

.hero-left h1 em {
  font-style: normal;
  color: #a8c47a;
}

.hero-sub {
  font-size: 1rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.6;
  margin-bottom: 2.5rem;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0,0,0,0.3);
  margin-bottom: 1rem;
}
.search-bar svg { width: 18px; height: 18px; color: #9ca3af; flex-shrink: 0; margin-left: 1rem; }
.search-bar input { flex: 1; padding: .9rem .75rem; border: none; outline: none; font-size: .95rem; color: #1a1a0e; background: transparent; }
.search-bar input::placeholder { color: #b8b0a0; }
.search-bar button { padding: .9rem 1.5rem; background: #515F37; color: #fff; border: none; cursor: pointer; font-weight: 700; font-size: .9rem; white-space: nowrap; }
.search-bar button:hover { background: #3d4a28; }

.search-pills {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 2.25rem;
}
.pills-label {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.4);
  white-space: nowrap;
}
.pill {
  font-size: 0.75rem;
  font-weight: 600;
  color: rgba(255,255,255,0.65);
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 100px;
  padding: 0.25rem 0.7rem;
  text-decoration: none;
  white-space: nowrap;
}
.pill:hover { background: rgba(255,255,255,0.15); color: #fff; }

.hero-ctas {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.cta-map {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: .7rem 1.4rem;
  background: rgba(255,255,255,0.1);
  border: 1.5px solid rgba(255,255,255,0.25);
  border-radius: 10px;
  color: #fff;
  font-weight: 700;
  font-size: .875rem;
  text-decoration: none;
}
.cta-map:hover { background: rgba(255,255,255,0.18); }
.cta-link {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.5);
  text-decoration: none;
  font-weight: 500;
}
.cta-link:hover { color: #a8c47a; }

.hero-right {
  position: relative;
  background: #c8bfa0;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.hero-illus {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

/* ══ TRUST STRIP ═════════════════════════════════════════════════ */
.trust-strip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  background: #fff;
  border-bottom: 1px solid #ebe8e0;
}
.trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 2rem 4rem;
  gap: 0.25rem;
}
.trust-item strong {
  font-size: 2.4rem;
  font-weight: 900;
  color: #14231a;
  letter-spacing: -0.03em;
  line-height: 1;
}
.trust-item strong span {
  color: #515F37;
}
.trust-item > span {
  font-size: 0.78rem;
  color: #8a8070;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.trust-sep {
  width: 1px;
  height: 40px;
  background: #ebe8e0;
  flex-shrink: 0;
}

/* ══ NOS SERVICES ════════════════════════════════════════════════ */
.services-section {
  padding: 7rem 0;
  background: #f7f3eb;
}
.container { max-width: 1100px; margin: 0 auto; padding: 0 3rem; }

.eyebrow {
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #515F37;
  margin-bottom: 0.75rem;
}
.eyebrow--dark { color: #14231a; }
.eyebrow--light { color: #c5bb9a; }

.section-title {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 900;
  color: #14231a;
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin-bottom: 4rem;
}

.services-grid { display: flex; flex-direction: column; gap: 1.5rem; }

.svc-card {
  display: flex;
  align-items: center;
  gap: 4rem;
  background: #fff;
  border-radius: 20px;
  padding: 3rem;
  border: 1px solid rgba(81,95,55,0.08);
}
.svc-card--reverse { flex-direction: row-reverse; }

.svc-illus {
  flex: 0 0 auto;
  width: 180px;
}
.svc-illus img {
  width: 100%; height: auto;
  object-fit: contain;
  filter: drop-shadow(0 8px 20px rgba(81,95,55,0.12));
}

.svc-text { flex: 1; }

.svc-tag {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #515F37;
  background: rgba(81,95,55,0.08);
  border-radius: 100px;
  padding: 0.3rem 0.75rem;
  margin-bottom: 0.875rem;
}
.svc-tag--green {
  color: #14231a;
  background: #a8c47a33;
}

.svc-text h3 {
  font-size: 1.5rem;
  font-weight: 800;
  color: #14231a;
  margin-bottom: 0.75rem;
  letter-spacing: -0.02em;
}
.svc-text p {
  font-size: 0.9rem;
  color: #6b6347;
  line-height: 1.8;
  margin-bottom: 1.25rem;
}

.svc-services {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-bottom: 1.5rem;
}
.svc-services span {
  font-size: 0.72rem;
  font-weight: 600;
  color: #515F37;
  background: rgba(81,95,55,0.07);
  border-radius: 100px;
  padding: 0.25rem 0.65rem;
}

.svc-cta {
  font-size: 0.875rem;
  font-weight: 700;
  color: #14231a;
  text-decoration: none;
  border-bottom: 2px solid #a8c47a;
  padding-bottom: 0.1rem;
}
.svc-cta:hover { border-color: #515F37; }

/* ══ COMMENT ÇA MARCHE ═══════════════════════════════════════════ */
.how-section {
  padding: 7rem 0 0;
  background: #fff;
  overflow: hidden;
}

.how-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-bottom: 5rem;
}

.how-step {
  position: relative;
  padding: 2rem;
  border-radius: 16px;
  background: #f7f3eb;
}

.how-num {
  display: block;
  font-size: 3.5rem;
  font-weight: 900;
  color: rgba(81,95,55,0.12);
  letter-spacing: -0.04em;
  line-height: 1;
  margin-bottom: 0.75rem;
}

.how-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  background: #14231a;
  border-radius: 14px;
  color: #a8c47a;
  margin-bottom: 1.25rem;
}

.how-step h4 {
  font-size: 1.05rem;
  font-weight: 800;
  color: #14231a;
  margin-bottom: 0.6rem;
  letter-spacing: -0.01em;
}
.how-step p {
  font-size: 0.85rem;
  color: #6b6347;
  line-height: 1.7;
}

.how-illus {
  line-height: 0;
  overflow: hidden;
}
.how-illus img {
  width: 100%;
  max-height: 260px;
  object-fit: cover;
  object-position: center 30%;
  display: block;
  filter: saturate(0.9);
}

/* ══ FAQ — ARBRES ════════════════════════════════════════════════ */
.faq-section {
  position: relative;
  background: #d6cda4;
  padding: 5rem 0 0;
  overflow: hidden;
}

.faq-header {
  text-align: center;
  padding: 0 2rem;
  margin-bottom: 3rem;
}
.faq-header h2 {
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 900;
  color: #1a1a0e;
  letter-spacing: -0.02em;
}

.trees-row {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 1.5rem;
  padding: 0 2rem;
  max-width: 1000px;
  margin: 0 auto;
}

.tree-item {
  flex: 0 0 auto;
  width: 200px;
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  text-decoration: none;
}

.tree-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #3d3820;
  background: rgba(255,255,255,0.45);
  border-radius: 100px;
  padding: 0.3rem 0.75rem;
  margin-bottom: 0.75rem;
  white-space: nowrap;
}

.tree-item img {
  width: 100%;
  height: auto;
  display: block;
  pointer-events: none;
}
.tree-item:hover { filter: drop-shadow(0 12px 24px rgba(81,95,55,0.35)); }

.faq-answer {
  min-height: 56px;
  text-align: center;
  padding: 1rem 3rem;
  font-size: 0.9rem;
  color: #3d3820;
  line-height: 1.7;
  max-width: 600px;
  margin: 1.5rem auto 0;
  background: rgba(255,255,255,0.6);
  border-radius: 14px;
  backdrop-filter: blur(4px);
  opacity: 0;
}
.faq-answer.visible { opacity: 1; }

.faq-ground {
  margin-top: 2rem;
  overflow: hidden;
  line-height: 0;
}
.faq-ground img {
  width: 100%;
  max-width: 900px;
  display: block;
  margin: 0 auto;
  object-fit: contain;
}

/* ══ RESPONSIVE ══════════════════════════════════════════════════ */
@media (max-width: 1024px) {
  .hero-left { padding: 4rem 3rem; }
  .trust-item { padding: 1.75rem 2.5rem; }
}

@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-right { height: 300px; }
  .hero-left { padding: 3.5rem 2rem; }
  .how-grid { grid-template-columns: 1fr; gap: 1rem; }
  .svc-card, .svc-card--reverse { flex-direction: column; gap: 1.5rem; text-align: center; padding: 2rem; }
  .svc-illus { width: 130px; }
  .svc-services { justify-content: center; }
  .trust-item { padding: 1.5rem 1.5rem; }
  .trees-row { gap: 1rem; }
  .tree-item { width: 150px; }
}

@media (max-width: 600px) {
  .container { padding: 0 1.5rem; }
  .services-section, .how-section { padding: 4rem 0 0; }
  .trees-row { flex-wrap: wrap; justify-content: center; }
  .tree-item { width: 140px; }
  .trust-strip { flex-wrap: wrap; }
  .trust-sep { display: none; }
  .trust-item { padding: 1.25rem 2rem; }
  .search-pills { display: none; }
}
</style>

<script>
const faqAnswer = document.getElementById('faqAnswer');
document.querySelectorAll('.tree-item').forEach(tree => {
  tree.addEventListener('mouseenter', () => {
    const answer = tree.getAttribute('data-answer');
    if (faqAnswer && answer) {
      faqAnswer.textContent = answer;
      faqAnswer.classList.add('visible');
    }
  });
  tree.addEventListener('mouseleave', () => {
    if (faqAnswer) faqAnswer.classList.remove('visible');
  });
});
</script>
