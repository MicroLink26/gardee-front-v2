---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3002/api';

let featured: unknown[] = [];
try {
  const res = await fetch(`${API_URL}/users/ranking?pageSize=3`);
  if (res.ok) {
    const data = await res.json() as { items: unknown[] };
    featured = data.items;
  }
} catch { /* silencieux en dev */ }

interface Prestataire {
  _id: string;
  prenom: string;
  nom: string;
  ville: string;
  prestations: string[];
  averageRating: number;
  numberOfReviews: number;
  tarifHoraire?: number;
  profil_image?: { secure_url: string };
}
---
<BaseLayout
  title="Trouvez votre jardinier"
  description="Gardee met en relation les particuliers avec des jardiniers professionnels vérifiés. Le Uber du jardinage."
>
  <Navbar />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="eyebrow">Le jardinier, quand vous voulez</span>
      <h1>Votre jardin mérite<br />le meilleur</h1>
      <p class="hero-sub">Des jardiniers vérifiés, disponibles près de chez vous.</p>

      <div class="choices">
        <a href="/carte" class="choice choice-primary">
          <div class="choice-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" y1="3" x2="9" y2="18"></line><line x1="15" y1="6" x2="15" y2="21"></line></svg>
          </div>
          <div class="choice-text">
            <strong>Trouver mon jardinier</strong>
            <span>Carte interactive · Filtres · Disponibilités</span>
          </div>
          <span class="choice-arrow">→</span>
        </a>

        <a href="/classement" class="choice choice-secondary">
          <div class="choice-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
          </div>
          <div class="choice-text">
            <strong>Top jardiniers</strong>
            <span>Les mieux notés de votre région</span>
          </div>
          <span class="choice-arrow">→</span>
        </a>
      </div>

      <a href="/postuler" class="apply-link">Vous êtes jardinier ? <span>Rejoindre Gardee →</span></a>
    </div>
  </section>

  <!-- COMMENT ÇA MARCHE -->
  <section class="how">
    <div class="container">
      <h2>Comment ça marche ?</h2>
      <div class="steps">
        <div class="step">
          <div class="step-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
          <h3>Cherchez</h3>
          <p>Trouvez le bon jardinier par service, note ou localisation sur la carte</p>
        </div>
        <div class="step-divider"></div>
        <div class="step">
          <div class="step-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          </div>
          <h3>Réservez</h3>
          <p>Choisissez un créneau disponible et réservez en quelques clics</p>
        </div>
        <div class="step-divider"></div>
        <div class="step">
          <div class="step-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h3>Profitez</h3>
          <p>Votre jardinier intervient, échangez via la messagerie sécurisée</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRESTATAIRES EN VEDETTE -->
  {featured.length > 0 && (
    <section class="featured">
      <div class="container">
        <div class="section-header">
          <h2>Les mieux notés en ce moment</h2>
          <a href="/classement" class="see-all">Voir tous →</a>
        </div>
        <div class="featured-grid">
          {(featured as Prestataire[]).map((u) => (
            <a href={`/prestataires/${u._id}`} class="fcard">
              <div class="fcard-photo">
                {u.profil_image?.secure_url
                  ? <img src={u.profil_image.secure_url} alt={`${u.prenom} ${u.nom}`} loading="lazy" />
                  : <div class="fcard-initials">{u.prenom[0]}{u.nom[0]}</div>
                }
                {u.tarifHoraire && <span class="fcard-price">{u.tarifHoraire} €/h</span>}
              </div>
              <div class="fcard-body">
                <p class="fcard-name">{u.prenom} {u.nom}</p>
                <p class="fcard-ville">{u.ville}</p>
                {u.numberOfReviews > 0 && (
                  <div class="fcard-rating">
                    <span class="stars">{'★'.repeat(Math.round(u.averageRating))}{'☆'.repeat(5 - Math.round(u.averageRating))}</span>
                    <span>{u.averageRating.toFixed(1)} ({u.numberOfReviews})</span>
                  </div>
                )}
                <div class="fcard-tags">
                  {u.prestations.slice(0, 2).map(p => <span class="ftag">{p}</span>)}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

/* ── HERO ───────────────────────────────────────── */
.hero {
  min-height: calc(100vh - 68px);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #f5f2ea 0%, #fafaf9 55%, #f0fdf4 100%);
  padding: 4rem 2rem;
}

.hero-inner {
  text-align: center;
  max-width: 700px;
  animation: fadeUp 0.7s ease both;
}

.eyebrow {
  display: inline-block;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #16a34a;
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  padding: 0.3rem 0.9rem;
  border-radius: 999px;
  margin-bottom: 1.5rem;
}

h1 {
  font-size: clamp(2.5rem, 6vw, 4rem);
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: #111827;
  margin-bottom: 1rem;
}

.hero-sub {
  font-size: 1.1rem;
  color: #6b7280;
  margin-bottom: 3rem;
}

/* ── CHOICES ────────────────────────────────────── */
.choices {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-bottom: 2rem;
}

.choice {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  padding: 1.25rem 1.75rem;
  border-radius: 16px;
  text-decoration: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  animation: fadeUp 0.7s ease both;
}

.choice:first-child { animation-delay: 0.1s; }
.choice:last-child  { animation-delay: 0.2s; }

.choice:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 40px rgba(0,0,0,0.12);
}

.choice-primary {
  background: #16a34a;
  color: #fff;
}

.choice-secondary {
  background: #fff;
  color: #111827;
  border: 1.5px solid #e5e7eb;
}

.choice-icon {
  width: 52px;
  height: 52px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.choice-primary .choice-icon {
  background: rgba(255,255,255,0.2);
  color: #fff;
}

.choice-secondary .choice-icon {
  background: #f0fdf4;
  color: #16a34a;
}

.choice-text {
  flex: 1;
  text-align: left;
}

.choice-text strong {
  display: block;
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 0.2rem;
}

.choice-primary .choice-text span { opacity: 0.85; font-size: 0.875rem; }
.choice-secondary .choice-text span { color: #6b7280; font-size: 0.875rem; }

.choice-arrow {
  font-size: 1.25rem;
  opacity: 0.7;
  transition: transform 0.2s;
}

.choice:hover .choice-arrow { transform: translateX(4px); opacity: 1; }

.apply-link {
  font-size: 0.875rem;
  color: #9ca3af;
  text-decoration: none;
  animation: fadeUp 0.7s 0.3s ease both;
}

.apply-link span {
  color: #374151;
  font-weight: 500;
  border-bottom: 1px solid #d1d5db;
  transition: color 0.15s, border-color 0.15s;
}

.apply-link:hover span { color: #16a34a; border-color: #16a34a; }

/* ── HOW IT WORKS ───────────────────────────────── */
.how {
  padding: 5rem 0;
  background: #fff;
  border-top: 1px solid #f3f4f6;
}

.container { max-width: 1000px; margin: 0 auto; padding: 0 2rem; }

.how h2 {
  text-align: center;
  font-size: 1.75rem;
  font-weight: 800;
  margin-bottom: 3rem;
  color: #111827;
}

.steps {
  display: flex;
  align-items: flex-start;
  gap: 0;
}

.step {
  flex: 1;
  text-align: center;
  padding: 0 1.5rem;
}

.step-icon {
  width: 56px;
  height: 56px;
  background: #f0fdf4;
  border: 1.5px solid #bbf7d0;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1rem;
  color: #16a34a;
}

.step h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; color: #111827; }
.step p { font-size: 0.875rem; color: #6b7280; line-height: 1.6; }

.step-divider {
  width: 1px;
  height: 56px;
  background: linear-gradient(to bottom, transparent, #d1fae5, transparent);
  flex-shrink: 0;
  margin-top: 0;
  align-self: flex-start;
  margin-top: 28px; /* center with icon */
  border-right: 1.5px dashed #d1fae5;
  width: 0;
}

/* ── FEATURED ───────────────────────────────────── */
.featured {
  padding: 5rem 0;
  background: #fafaf8;
  border-top: 1px solid #f3f4f6;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 2rem;
}

.section-header h2 { font-size: 1.5rem; font-weight: 800; color: #111827; }

.see-all {
  font-size: 0.875rem;
  color: #16a34a;
  text-decoration: none;
  font-weight: 600;
}

.see-all:hover { text-decoration: underline; }

.featured-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.fcard {
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 16px;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  transition: transform 0.2s, box-shadow 0.2s;
}

.fcard:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.1); }

.fcard-photo {
  position: relative;
  height: 200px;
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
  overflow: hidden;
}

.fcard-photo img { width: 100%; height: 100%; object-fit: cover; }

.fcard-initials {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
  font-weight: 800;
  color: #065f46;
}

.fcard-price {
  position: absolute;
  bottom: 10px;
  right: 10px;
  background: #111827;
  color: #fff;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 700;
}

.fcard-body { padding: 1rem 1.25rem; }
.fcard-name { font-weight: 700; font-size: 0.95rem; margin-bottom: 0.2rem; }
.fcard-ville { color: #9ca3af; font-size: 0.8rem; margin-bottom: 0.5rem; }

.fcard-rating {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8rem;
  color: #6b7280;
  margin-bottom: 0.5rem;
}

.stars { color: #f59e0b; letter-spacing: -1px; }

.fcard-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }

.ftag {
  background: #f0fdf4;
  color: #15803d;
  border: 1px solid #d1fae5;
  padding: 0.15rem 0.55rem;
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 500;
}

/* ── ANIMATIONS ─────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── RESPONSIVE ─────────────────────────────────── */
@media (max-width: 768px) {
  .steps { flex-direction: column; align-items: center; gap: 2rem; }
  .step-divider { display: none; }
  .featured-grid { grid-template-columns: 1fr; }
  .choices { gap: 0.875rem; }
}

@media (max-width: 480px) {
  h1 { font-size: 2.25rem; }
  .choice { padding: 1rem 1.25rem; gap: 1rem; }
  .choice-text strong { font-size: 1rem; }
}
</style>
