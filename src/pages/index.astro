---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'Gardee',
  'url': 'https://gardee.fr',
  'description': 'Gardee connecte les particuliers avec des jardiniers professionnels vérifiés. Tonte, taille, élagage, paysagisme.',
  'potentialAction': {
    '@type': 'SearchAction',
    'target': {
      '@type': 'EntryPoint',
      'urlTemplate': 'https://gardee.fr/recherche?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};
---
<BaseLayout
  title="Trouvez votre jardinier"
  description="Gardee connecte les particuliers avec des jardiniers professionnels vérifiés. Tonte, taille, élagage, paysagisme."
  jsonLd={jsonLd}
>
  <Navbar />

  <!-- ══ HERO ═══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-left">
      <span class="hero-badge">
        <svg viewBox="0 0 10 10" width="8" height="8" fill="currentColor"><circle cx="5" cy="5" r="5"/></svg>
        Plateforme certifiée
      </span>
      <h1 data-i18n-key="hero-title">Votre jardin mérite<br>le <em>meilleur</em></h1>
      <p class="hero-sub" data-i18n-key="hero-sub">Des jardiniers professionnels vérifiés, près de chez vous. Comparez, réservez, profitez.</p>

      <div class="search-pills">
        <span class="pills-label">Populaire :</span>
        <a href="/carte?prestation=tonte" class="pill">Tonte</a>
        <a href="/carte?prestation=taille" class="pill">Taille de haies</a>
        <a href="/carte?prestation=élagage" class="pill">Élagage</a>
        <a href="/carte?prestation=paysagiste" class="pill">Paysagiste</a>
      </div>

      <div class="hero-ctas">
        <a href="/carte" class="cta-map">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
          Voir la carte
        </a>
        <a href="/postuler" class="cta-link">Vous êtes jardinier ? →</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-video-wrap">
        <video
          id="hero-video"
          class="hero-video"
          src="/hero.mp4"
          muted
          loop
          playsinline
          preload="metadata"
        ></video>
      </div>
      <a class="hero-floating-card" id="hero-badge" href="#" style="display:none;text-decoration:none">
        <div class="hfc-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="hfc-text">
          <strong>Jardinier trouvé !</strong>
          <span id="hero-badge-dist">Près de chez vous</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ══ CHIFFRES CLÉS ══════════════════════════════════════════════ -->
  <div class="trust-strip reveal">
    <div class="trust-item">
      <div class="trust-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <strong>500<span>+</span></strong>
      <span>jardiniers vérifiés</span>
    </div>
    <div class="trust-sep"></div>
    <div class="trust-item">
      <div class="trust-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <strong>4,8<span>★</span></strong>
      <span>note moyenne</span>
    </div>
    <div class="trust-sep"></div>
    <div class="trust-item">
      <div class="trust-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <strong>12 000<span>+</span></strong>
      <span>jardins entretenus</span>
    </div>
  </div>

  <!-- ══ NOS SERVICES ═══════════════════════════════════════════════ -->
  <section class="services-section reveal">
    <div class="container">
      <p class="eyebrow">NOS SERVICES</p>
      <h2 class="section-title">Une plateforme,<br>deux façons d'en profiter</h2>
      <div class="services-grid">

        <div class="svc-card">
          <div class="svc-accent svc-accent--client"></div>
          <div class="svc-text">
            <div class="svc-tag">Pour les propriétaires</div>
            <h3>Sublimez votre jardin</h3>
            <p>Choisissez parmi les meilleurs jardiniers, paysagistes et élagueurs de votre région. Comparez les avis et réservez en quelques clics.</p>
            <ul class="svc-checklist">
              <li>Profils vérifiés et notés</li>
              <li>Avis clients authentiques</li>
              <li>Réservation en ligne simple</li>
            </ul>
            <div class="svc-services">
              <span>Tonte</span><span>Taille</span><span>Élagage</span><span>Paysagiste</span>
            </div>
            <a href="/carte" class="svc-cta">Trouver un jardinier →</a>
          </div>
        </div>

        <div class="svc-card svc-card--pro">
          <div class="svc-accent svc-accent--pro"></div>
          <div class="svc-text">
            <div class="svc-tag svc-tag--green">Pour les professionnels</div>
            <h3>Développez votre activité</h3>
            <p>Rejoignez Gardee et gagnez en visibilité locale. Collectez des avis vérifiés, montez dans le classement et remplissez votre carnet de commandes.</p>
            <ul class="svc-checklist">
              <li>Visibilité locale immédiate</li>
              <li>Gestion des réservations</li>
              <li>Profil pro personnalisé</li>
            </ul>
            <div class="svc-services">
              <span>Visibilité</span><span>Avis vérifiés</span><span>Réservations</span>
            </div>
            <a href="/postuler" class="svc-cta svc-cta--pro">Postuler →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ COMMENT ÇA MARCHE ══════════════════════════════════════════ -->
  <section class="how-section reveal">
    <div class="container">
      <p class="eyebrow eyebrow--dark">COMMENT ÇA MARCHE</p>
      <h2 class="section-title">Simple comme bonjour</h2>
      <div class="how-grid">

        <div class="how-step">
          <div class="how-step-top">
            <span class="how-num">01</span>
            <div class="how-connector"></div>
          </div>
          <!-- Placeholder vidéo -->
          <div class="video-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <span>Vidéo à venir</span>
          </div>
          <div class="how-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="26" height="26"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h4>Décrivez vos besoins</h4>
          <p>Entrez le service recherché et votre localisation pour voir les jardiniers disponibles près de chez vous.</p>
        </div>

        <div class="how-step">
          <div class="how-step-top">
            <span class="how-num">02</span>
            <div class="how-connector"></div>
          </div>
          <!-- Placeholder vidéo -->
          <div class="video-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <span>Vidéo à venir</span>
          </div>
          <div class="how-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="26" height="26"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h4>Choisissez votre jardinier</h4>
          <p>Consultez les profils, les avis clients et les tarifs. Comparez et sélectionnez le professionnel qui vous convient.</p>
        </div>

        <div class="how-step">
          <div class="how-step-top">
            <span class="how-num">03</span>
          </div>
          <!-- Placeholder vidéo -->
          <div class="video-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <span>Vidéo à venir</span>
          </div>
          <div class="how-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="26" height="26"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h4>Profitez de votre jardin</h4>
          <p>Réservez directement en ligne. Votre jardinier intervient au créneau choisi. Laissez un avis pour la communauté.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ CTA BAND ═══════════════════════════════════════════════════ -->
  <section class="cta-band reveal">
    <div class="container cta-band-inner">
      <div class="cta-band-text">
        <h2>Prêt à sublimer votre jardin ?</h2>
        <p>Rejoignez des milliers de propriétaires qui font confiance à Gardee</p>
      </div>
      <div class="cta-band-actions">
        <a href="/carte" class="cta-band-btn cta-band-btn--primary">Trouver un jardinier</a>
        <a href="/postuler" class="cta-band-btn cta-band-btn--secondary">Devenir prestataire</a>
      </div>
    </div>
  </section>

  <!-- ══ FAQ ════════════════════════════════════════════════════════ -->
  <section class="faq-section reveal">
    <div class="container">
      <div class="faq-header">
        <p class="eyebrow">VOS QUESTIONS</p>
        <h2>Questions fréquentes</h2>
        <p class="faq-sub">Tout ce que vous voulez savoir sur Gardee</p>
      </div>

      <div class="faq-list">
        <details class="faq-item">
          <summary>Comment trouver un jardinier près de moi ?</summary>
          <div class="faq-body">Utilisez la carte interactive ou la barre de recherche pour trouver un jardinier. Entrez votre service et votre ville, consultez les profils avec leurs avis, et contactez le professionnel qui vous convient.</div>
        </details>
        <details class="faq-item">
          <summary>Les jardiniers sont-ils vérifiés ?</summary>
          <div class="faq-body">Oui, chaque prestataire est validé manuellement par notre équipe avant d'apparaître sur la plateforme. Nous vérifions leur identité, leurs qualifications et leur statut professionnel.</div>
        </details>
        <details class="faq-item">
          <summary>Pourquoi rejoindre Gardee en tant que professionnel ?</summary>
          <div class="faq-body">Gardee vous offre une visibilité locale immédiate, des avis vérifiés qui valorisent votre expertise, et une interface simple pour gérer vos réservations. C'est gratuit pour démarrer.</div>
        </details>
        <details class="faq-item">
          <summary>Comment contacter le support Gardee ?</summary>
          <div class="faq-body">Notre équipe est disponible via la <a href="/contact">page contact</a>. Vous pouvez aussi nous écrire à <a href="mailto:contact@gardee.fr">contact@gardee.fr</a>. Nous répondons sous 24h ouvrées.</div>
        </details>
        <details class="faq-item">
          <summary>Quelles sont les prochaines fonctionnalités ?</summary>
          <div class="faq-body">Nous développons une messagerie sécurisée, un paiement en ligne intégré et un calendrier en temps réel. L'objectif : gérer tout votre parcours sans quitter Gardee.</div>
        </details>
      </div>

      <div class="faq-cta">
        <span>Vous ne trouvez pas votre réponse ?</span>
        <a href="/contact">Nous contacter →</a>
      </div>
    </div>
  </section>

  <Footer />

  <script define:vars={{ apiUrl: import.meta.env.PUBLIC_API_URL ?? 'https://site--gardee-backend--fg6zdpvl2w9z.code.run/api' }}>
    if ('geolocation' in navigator) {
      navigator.geolocation.getCurrentPosition(async (pos) => {
        try {
          const { latitude: lat, longitude: lng } = pos.coords;
          const res = await fetch(`${apiUrl}/prestataires/ranking?pageSize=20`);
          if (!res.ok) return;
          const { items } = await res.json();
          let minDist = Infinity;
          let nearestId = null;
          for (const u of items) {
            if (!u.location) continue;
            const [uLng, uLat] = u.location.coordinates;
            const dLat = (uLat - lat) * Math.PI / 180;
            const dLng = (uLng - lng) * Math.PI / 180;
            const a = Math.sin(dLat / 2) ** 2 + Math.cos(lat * Math.PI / 180) * Math.cos(uLat * Math.PI / 180) * Math.sin(dLng / 2) ** 2;
            const d = 6371 * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            if (d < minDist) { minDist = d; nearestId = u._id; }
          }
          if (minDist === Infinity || !nearestId) return;
          const badge = document.getElementById('hero-badge');
          const distEl = document.getElementById('hero-badge-dist');
          if (!badge || !distEl) return;
          const km = minDist < 1 ? '< 1 km' : `${Math.round(minDist)} km`;
          distEl.textContent = `À ${km} de chez vous`;
          badge.setAttribute('href', `/prestataires/${nearestId}/`);
          badge.style.display = '';
        } catch {}
      }, () => {}, { timeout: 6000, maximumAge: 300000 });
    }
  </script>

  <script>
    // Hero video autoplay — compatible iOS/Android
    (function() {
      const video = document.getElementById('hero-video') as HTMLVideoElement | null;
      if (!video) return;
      // Attempt play — required on some mobile browsers even with muted+playsinline
      const tryPlay = () => {
        video.play().catch(() => {
          // Fallback: show static poster if video can't play
          video.style.display = 'none';
        });
      };
      if (document.readyState === 'complete') {
        tryPlay();
      } else {
        window.addEventListener('load', tryPlay, { once: true });
      }
      // Also trigger on first user interaction (some strict mobile browsers)
      document.addEventListener('touchstart', () => {
        if (video.paused) video.play().catch(() => {});
      }, { once: true, passive: true });
    })();
  </script>

  <script>
    // Apply saved language on page load
    const PAGE_TRANSLATIONS: Record<string, Record<string, string>> = {
      en: {
        'hero-title': 'Your garden deserves<br>the <em>best</em>',
        'hero-sub': 'Verified professional gardeners, near you. Compare, book, enjoy.',
      },
    };

    const lang = localStorage.getItem('gardee-lang') ?? 'fr';
    if (lang === 'en') {
      document.querySelectorAll('[data-i18n-key]').forEach(el => {
        const key = el.getAttribute('data-i18n-key')!;
        if (PAGE_TRANSLATIONS.en[key]) el.innerHTML = PAGE_TRANSLATIONS.en[key];
      });
    }
  </script>
</BaseLayout>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

/* ══ HERO ════════════════════════════════════════════════════════ */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: calc(100vh - 56px);
  background: linear-gradient(155deg, #edf2e4 0%, #dce6ca 100%);
}

.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 5rem 4rem 5rem 5rem;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #3a4f22;
  background: rgba(81, 95, 55, 0.12);
  border: 1px solid rgba(81, 95, 55, 0.22);
  border-radius: 100px;
  padding: 0.35rem 0.9rem;
  width: fit-content;
  margin-bottom: 1.75rem;
}
.hero-badge svg { color: #5f7a39; }

.hero-left h1 {
  font-size: clamp(2.8rem, 4.5vw, 4.4rem);
  font-weight: 900;
  line-height: 1.06;
  color: #0f1a0a;
  letter-spacing: -0.03em;
  margin-bottom: 1.1rem;
}

.hero-left h1 em {
  font-style: normal;
  color: #515F37;
  position: relative;
}
.hero-left h1 em::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: 4px;
  height: 3px;
  background: linear-gradient(90deg, #a8c47a, #515F37);
  border-radius: 2px;
  opacity: 0.5;
}

.hero-sub {
  font-size: 1.05rem;
  color: #4a5235;
  line-height: 1.65;
  margin-bottom: 2.25rem;
  max-width: 440px;
}

.search-pills {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}
.pills-label { font-size: 0.73rem; color: #6b6347; white-space: nowrap; }
.pill {
  font-size: 0.73rem; font-weight: 600;
  color: #515F37;
  background: rgba(81,95,55,0.09);
  border: 1px solid rgba(81,95,55,0.18);
  border-radius: 100px;
  padding: 0.25rem 0.7rem;
  text-decoration: none; white-space: nowrap;
  transition: background 0.15s, border-color 0.15s;
}
.pill:hover { background: rgba(81,95,55,0.16); border-color: rgba(81,95,55,0.3); }

.hero-ctas {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  flex-wrap: wrap;
}
.cta-map {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.75rem 1.5rem;
  background: #515F37;
  border: 1.5px solid #515F37;
  border-radius: 12px;
  color: #fff;
  font-weight: 700;
  font-size: 0.875rem;
  text-decoration: none;
  transition: background 0.15s, transform 0.15s;
}
.cta-map:hover { background: #3d4a28; transform: translateY(-1px); }
.cta-link {
  font-size: 0.875rem; color: #4a5235;
  text-decoration: none; font-weight: 600;
  border-bottom: 1.5px solid rgba(81,95,55,0.3);
  padding-bottom: 1px;
  transition: color 0.15s, border-color 0.15s;
}
.cta-link:hover { color: #515F37; border-color: #515F37; }

.hero-right {
  position: relative;
  background: #0f0f0f;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.hero-video-wrap {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 400px;
  overflow: hidden;
}

.hero-video {
  width: 100%;
  height: 100%;
  min-height: 400px;
  object-fit: cover;
  display: block;
}

.hero-floating-card {
  position: absolute;
  bottom: 2.5rem;
  left: 2rem;
  background: rgba(255,255,255,0.95);
  border-radius: 14px;
  padding: 0.875rem 1.1rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  backdrop-filter: blur(8px);
  z-index: 2;
  animation: floatUp 0.6s ease 0.3s both;
}
@keyframes floatUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}
.hfc-icon {
  width: 32px; height: 32px;
  background: #515F37; color: #fff;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.hfc-text { display: flex; flex-direction: column; gap: 2px; }
.hfc-text strong { font-size: 0.825rem; font-weight: 700; color: #14231a; }
.hfc-text span { font-size: 0.72rem; color: #6b7280; }

/* ══ TRUST STRIP ═════════════════════════════════════════════════ */
.trust-strip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  background: #FCFAF5;
  border-bottom: 1px solid #ebe8e0;
}
.trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 2rem 4rem;
  gap: 0.25rem;
}
.trust-icon {
  width: 44px; height: 44px;
  background: rgba(81,95,55,0.07);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  color: #515F37;
  margin-bottom: 0.5rem;
}
.trust-item strong {
  font-size: 2.2rem;
  font-weight: 900;
  color: #14231a;
  letter-spacing: -0.03em;
  line-height: 1;
}
.trust-item strong span { color: #515F37; }
.trust-item > span {
  font-size: 0.75rem;
  color: #8a8070;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.trust-sep {
  width: 1px; height: 60px;
  background: #ebe8e0;
  flex-shrink: 0;
}

/* ══ NOS SERVICES ════════════════════════════════════════════════ */
.services-section {
  padding: 7rem 0;
  background: #f7f3eb;
}
.container { max-width: 1100px; margin: 0 auto; padding: 0 3rem; }

.eyebrow {
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #515F37;
  margin-bottom: 0.75rem;
}
.eyebrow--dark { color: #515F37; }

.section-title {
  font-size: clamp(1.9rem, 3.5vw, 2.8rem);
  font-weight: 900;
  color: #14231a;
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin-bottom: 3.5rem;
}

.services-grid {
