---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
---
<BaseLayout
  title="Trouvez votre jardinier"
  description="Gardee connecte les particuliers avec des jardiniers professionnels vérifiés. Tonte, taille, élagage, paysagisme."
>
  <Navbar />

  <!-- ══ HERO ═══════════════════════════════════════════════════════ -->
  <section class="hero-section">
    <div class="hero-inner">
      <div class="hero-content">
        <span class="hero-eyebrow">La plateforme jardinage de confiance</span>
        <h1>Trouvez votre<br><em>meilleur jardinier</em></h1>
        <form class="hero-search" action="/classement" method="get">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input name="q" type="search" placeholder="Service, jardinier, ville…" autocomplete="off" />
          <button type="submit">Rechercher</button>
        </form>
        <div class="hero-ctas">
          <a href="/carte" class="cta-btn cta-secondary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
            Voir la carte
          </a>
          <a href="/classement" class="cta-btn cta-primary">Classement →</a>
          <a href="/postuler" class="cta-btn cta-ghost">Devenir prestataire</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ NOS SERVICES ═══════════════════════════════════════════ -->
  <section class="services-section">
    <div class="container">
      <p class="eyebrow">NOS SERVICES</p>
      <div class="services-grid">

        <div class="svc-card">
          <div class="svc-illus">
            <img src="/futur-left.png" alt="Détenteurs de jardins" />
          </div>
          <div class="svc-text">
            <h3>Pour les détenteurs de jardins</h3>
            <p>Pour sublimer votre jardin, choisissez le meilleur jardinier, paysagiste, élagueur ou pisciniste de votre région. Ou faites confiance à vos voisins ou aux jeunes novices qui pourront réaliser des travaux à moindre coût.</p>
            <a href="/carte" class="svc-cta">Trouver un jardinier <span>→</span></a>
          </div>
        </div>

        <div class="svc-card svc-card--reverse">
          <div class="svc-illus">
            <img src="/futur-right.png" alt="Pour les jardiniers" />
          </div>
          <div class="svc-text">
            <h3>Pour les jardiniers</h3>
            <p>Postulez et devenez le meilleur dans votre activité, et dans votre région. Gagnez le plus d'avis positifs pour monter dans le classement et acquérir un maximum de visibilité.</p>
            <a href="/postuler" class="svc-cta">Postuler <span>→</span></a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ FAQ — arbres pictos ════════════════════════════════════ -->
  <section class="faq-section">
    <div class="faq-header">
      <p class="eyebrow eyebrow--light">LES QUESTIONS COURANTES</p>
      <h2>Et le but dans l'avenir ?</h2>
    </div>

    <div class="trees-row">

      <a href="/contact" class="tree-item" data-answer="Utilisez la carte ou la barre de recherche pour trouver un jardinier. Consultez son profil, ses avis, et réservez un créneau directement sur la plateforme.">
        <img src="/arbreUtiliser.png" alt="Comment utiliser Gardee ?" />
      </a>

      <a href="/postuler" class="tree-item" data-answer="Gardee vous offre une visibilité locale, des avis vérifiés qui valorisent votre expertise, et une interface simple pour gérer vos réservations.">
        <img src="/arbrePostuler.png" alt="Pourquoi postuler sur Gardee ?" />
      </a>

      <a href="/contact" class="tree-item" data-answer="Notre équipe est disponible via la page contact. Vous pouvez aussi nous écrire à contact@gardee.fr pour toute question.">
        <img src="/arbreContacter.png" alt="Qui contacter ?" />
      </a>

      <a href="/contact" class="tree-item" data-answer="Nous développons une messagerie sécurisée, un paiement en ligne, et un calendrier en temps réel. L'objectif : gérer tout votre parcours sans quitter Gardee.">
        <img src="/arbreBut.png" alt="Quel but sur le long terme ?" />
      </a>

    </div>

    <!-- Bulle réponse dynamique -->
    <div class="faq-answer" id="faqAnswer"></div>

    <!-- Illustration de fond -->
    <div class="faq-ground">
      <img src="/bg-faq.png" alt="" aria-hidden="true" />
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { margin: 0; padding: 0; }

/* ══ HERO ════════════════════════════════════════════════════════ */
.hero-section {
  min-height: 60vh;
  display: flex;
  align-items: center;
  background: linear-gradient(
    to bottom,
    #0d1b2a  0%,
    #1b3a5c 18%,
    #c97a3c 52%,
    #e8954d 76%,
    #f5c06b 100%
  );
  padding: 4rem 3rem;
}

.hero-inner {
  max-width: 1100px;
  margin: 0 auto;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-content {
  max-width: 560px;
  text-align: center;
}

.hero-eyebrow {
  display: block;
  font-size: clamp(0.65rem, 1.8vw, 0.85rem);
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #f5c06b;
  margin-bottom: 0.75rem;
}

.hero-content h1 {
  font-size: clamp(2.4rem, 6vw, 5rem);
  font-weight: 900;
  line-height: 1.08;
  color: #fff;
  margin: 0 0 2rem;
  letter-spacing: -0.02em;
  filter: drop-shadow(0 2px 18px rgba(0,0,0,0.55));
}

.hero-content h1 em { font-style: normal; color: #f5c06b; }

.hero-search {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,.95);
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0,0,0,.25);
  margin-bottom: 1.25rem;
}

.hero-search svg { width: 18px; height: 18px; color: #9ca3af; flex-shrink: 0; margin-left: 1rem; }
.hero-search input { flex: 1; padding: .85rem .75rem; border: none; outline: none; font-size: .95rem; color: #1a1a0e; background: transparent; }
.hero-search input::placeholder { color: #b8b0a0; }
.hero-search button { padding: .85rem 1.5rem; background: #515F37; color: #fff; border: none; cursor: pointer; font-weight: 700; font-size: .9rem; white-space: nowrap; }
.hero-search button:hover { background: #3d4a28; }

.hero-ctas { display: flex; align-items: center; justify-content: center; gap: .75rem; flex-wrap: wrap; }

.cta-btn { padding: .6rem 1.25rem; border-radius: 10px; text-decoration: none; font-weight: 700; font-size: .875rem; display: inline-flex; align-items: center; gap: .4rem; }
.cta-primary { background: #515F37; color: #fff; }
.cta-primary:hover { background: #3d4a28; }
.cta-secondary { background: rgba(255,255,255,.18); color: #fff; border: 1.5px solid rgba(255,255,255,.5); }
.cta-secondary:hover { background: rgba(255,255,255,.3); }
.cta-ghost { color: rgba(255,255,255,.75); font-weight: 500; font-size: .82rem; }
.cta-ghost:hover { color: #fff; }

/* ══ NOS SERVICES ════════════════════════════════════════════════ */
.services-section { padding: 6rem 0; background: #fff; }
.container { max-width: 1100px; margin: 0 auto; padding: 0 3rem; }

.eyebrow {
  font-size: 0.68rem; font-weight: 800;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: #515F37; margin-bottom: 2.5rem;
}
.eyebrow--light { color: #d6cda4; }

.services-grid { display: flex; flex-direction: column; gap: 3.5rem; }

.svc-card {
  display: flex;
  align-items: center;
  gap: 4rem;
}
.svc-card--reverse { flex-direction: row-reverse; }

.svc-illus {
  flex: 0 0 auto;
  width: 200px;
}
.svc-illus img {
  width: 100%; height: auto;
  object-fit: contain;
  filter: drop-shadow(0 8px 20px rgba(81,95,55,0.15));
}

.svc-text { flex: 1; }
.svc-text h3 {
  font-size: 1.3rem; font-weight: 800;
  color: #1a1a0e; margin-bottom: 0.875rem;
  letter-spacing: -0.01em;
}
.svc-text p {
  font-size: 0.9rem; color: #6b6347;
  line-height: 1.8; margin-bottom: 1.5rem;
}
.svc-cta {
  font-size: 0.875rem; font-weight: 700;
  color: #515F37; text-decoration: none;
  border-bottom: 2px solid #d6cda4;
  padding-bottom: 0.15rem;
}
.svc-cta:hover { border-color: #515F37; }

/* ══ FAQ — ARBRES ════════════════════════════════════════════════ */
.faq-section {
  position: relative;
  background: #d6cda4;
  padding: 4rem 0 0;
  overflow: hidden;
}

.faq-header {
  text-align: center;
  padding: 0 2rem;
  margin-bottom: 2.5rem;
}
.faq-header h2 {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 900;
  color: #1a1a0e;
  letter-spacing: -0.02em;
}

.trees-row {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 1.5rem;
  padding: 0 2rem;
  max-width: 1000px;
  margin: 0 auto;
}

.tree-item {
  flex: 0 0 auto;
  width: 200px;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  cursor: pointer;
  text-decoration: none;
}

.tree-item img {
  width: 100%;
  height: auto;
  display: block;
  pointer-events: none;
}

.tree-item:hover {
  filter: drop-shadow(0 12px 24px rgba(81,95,55,0.35));
}

/* Answer bubble */
.faq-answer {
  min-height: 60px;
  text-align: center;
  padding: 1rem 3rem;
  font-size: 0.9rem;
  color: #3d3820;
  line-height: 1.7;
  max-width: 640px;
  margin: 1.5rem auto 0;
  background: rgba(255,255,255,0.55);
  border-radius: 16px;
  backdrop-filter: blur(4px);
  opacity: 0;
}
.faq-answer.visible { opacity: 1; }

/* Ground illustration */
.faq-ground {
  margin-top: 2rem;
  overflow: hidden;
  line-height: 0;
}
.faq-ground img {
  width: 100%;
  max-width: 900px;
  display: block;
  margin: 0 auto;
  object-fit: contain;
}

/* ══ RESPONSIVE ══════════════════════════════════════════════════ */
@media (max-width: 900px) {
  .hero-section { padding: 3rem 1.5rem; justify-content: center; }
  .hero-inner { justify-content: center; }
  .svc-card, .svc-card--reverse { flex-direction: column; gap: 1.5rem; text-align: center; }
  .svc-illus { width: 140px; }
  .trees-row { gap: 1rem; }
  .tree-item { width: 150px; }
}

@media (max-width: 600px) {
  .container { padding: 0 1.5rem; }
  .services-section { padding: 4rem 0; }
  .trees-row { flex-wrap: wrap; justify-content: center; }
  .tree-item { width: 140px; }
  .hero-content h1 { font-size: clamp(2rem, 10vw, 3rem); }
  .hero-search button { padding: .85rem 1rem; font-size: .82rem; }
  .hero-ctas { gap: .5rem; }
  .cta-btn { padding: .5rem .9rem; font-size: .8rem; }
}
</style>

<script>
// FAQ trees — afficher la réponse au hover
const faqAnswer = document.getElementById('faqAnswer');
document.querySelectorAll('.tree-item').forEach(tree => {
  tree.addEventListener('mouseenter', () => {
    const answer = tree.getAttribute('data-answer');
    if (faqAnswer && answer) {
      faqAnswer.textContent = answer;
      faqAnswer.classList.add('visible');
    }
  });
  tree.addEventListener('mouseleave', () => {
    if (faqAnswer) faqAnswer.classList.remove('visible');
  });
});
</script>
