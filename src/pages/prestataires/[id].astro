---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/astro/Navbar.astro';
import Footer from '../../components/astro/Footer.astro';
import Breadcrumbs from '../../components/vue/Breadcrumbs.vue';
import BookingWidget from '../../components/vue/BookingWidget.vue';

export async function getStaticPaths() {
  const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3002/api';
  try {
    const res = await fetch(`${apiUrl}/prestataires/all-ids`);
    if (!res.ok) return [];
    const { ids } = await res.json();
    return (ids ?? []).map((id: string) => ({ params: { id } }));
  } catch {
    return [];
  }
}

const { id } = Astro.params;
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3002/api';

const [profileRes, catsRes, reviewsRes] = await Promise.all([
  fetch(`${apiUrl}/prestataires/${id}`),
  fetch(`${apiUrl}/categories`),
  fetch(`${apiUrl}/prestataires/${id}/reviews?pageSize=5`),
]);

const { user } = await profileRes.json();
const prest = user?.prestataire ?? null;
const categories: Array<{ _id: string; name: string }> = await catsRes.json();
const { items: reviews = [], total: totalReviews = 0 } = await reviewsRes.json();

const catMap = new Map(categories.map(c => [c._id, c.name]));
const catName = (cid: string) => catMap.get(cid) ?? cid;

function starsArr(n: number) {
  const full = Math.min(Math.round(n ?? 0), 5);
  return { full, empty: Math.max(0, 5 - full) };
}

const CATEGORY_LABELS: Record<string, string> = {
  time: 'Délai',
  quality: 'Qualité',
  sympathy: 'Sympathie',
  value: 'Rapport qualité/prix',
  punctuality: 'Ponctualité',
};

const processedReviews = reviews.map((r: any) => {
  const d = r.ratingDetails as Record<string, number> | undefined;
  const vals = d ? Object.values(d).filter((v: unknown): v is number => typeof v === 'number') : [];
  const avg = vals.length ? vals.reduce((a: number, b: number) => a + b, 0) / vals.length : 0;
  const stars = starsArr(avg);
  const details = d ? Object.entries(d)
    .filter(([, v]) => typeof v === 'number')
    .map(([key, val]) => ({ key, label: CATEGORY_LABELS[key] ?? key, val: val as number, pct: Math.round((val as number / 5) * 100) }))
    : [];
  return {
    author: (r.requesterPrenom as string) || 'Client',
    date: new Date(r.ratingGivenAt as string).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }),
    comment: r.ratingComment as string | undefined,
    avgStr: avg.toFixed(1),
    starsFullStr: '★'.repeat(stars.full),
    starsEmptyStr: '★'.repeat(stars.empty),
    initial: ((r.requesterPrenom as string)?.[0] ?? '?').toUpperCase(),
    details,
    recommend: r.recommend as boolean | undefined,
  };
});

// Calcul des moyennes globales par catégorie
const categoryAverages = (() => {
  if (!reviews.length) return [];
  const sums: Record<string, { total: number; count: number }> = {};
  for (const r of reviews) {
    const d = (r as any).ratingDetails as Record<string, number> | undefined;
    if (!d) continue;
    for (const [key, val] of Object.entries(d)) {
      if (typeof val !== 'number') continue;
      if (!sums[key]) sums[key] = { total: 0, count: 0 };
      sums[key].total += val;
      sums[key].count += 1;
    }
  }
  return Object.entries(sums).map(([key, { total, count }]) => ({
    key, label: CATEGORY_LABELS[key] ?? key,
    avg: total / count,
    pct: Math.round((total / count / 5) * 100),
  }));
})();

const avatarIdx = parseInt(id.slice(-2), 16) % 4;
const defaultAvatars = ['/img/default-avatar.png', '/img/default-avatar2.png', '/img/default-avatar3.png', '/img/default-avatar4.png'];
const avatarSrc = prest?.profil_image?.secure_url ?? defaultAvatars[avatarIdx];

const fullName = user ? `${user.prenom} ${user.nom}` : 'Jardinier';
const pageTitle = user ? `${fullName} — Jardinier à ${prest?.ville ?? ''}` : 'Profil jardinier';
const pageDesc = prest?.description
  ? prest.description.slice(0, 155) + (prest.description.length > 155 ? '...' : '')
  : `Découvrez le profil de ${fullName}, jardinier professionnel à ${prest?.ville ?? ''} sur Gardee.`;

const memberSince = user ? new Date(user.createdAt).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' }) : '';

const profileUrl = `https://gardee.fr/prestataires/${id}/`;
const ogImageUrl = prest?.profil_image?.secure_url ?? 'https://gardee.fr/img/og-default.jpg';

const jsonLd = user ? {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  'name': `${fullName} — Jardinier professionnel`,
  'description': pageDesc,
  'image': ogImageUrl,
  'url': profileUrl,
  'telephone': user.telephone ?? undefined,
  'priceRange': prest?.tarifHoraire ? `${prest.tarifHoraire}€/h` : undefined,
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': prest?.ville ?? undefined,
    'postalCode': prest?.codePostal ?? undefined,
    'addressCountry': 'FR',
  },
  ...((prest?.numberOfReviews ?? 0) > 0 ? {
    'aggregateRating': {
      '@type': 'AggregateRating',
      'ratingValue': Number((prest?.averageRating ?? 0).toFixed(1)),
      'reviewCount': prest?.numberOfReviews,
      'bestRating': 5,
      'worstRating': 1,
    },
  } : {}),
} : undefined;
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  ogImage={ogImageUrl}
  ogType="profile"
  jsonLd={jsonLd}
>
  <Navbar />

  <div style="padding: 0.75rem 1.5rem; background: #f9f8f5; border-bottom: 1px solid #e5e1d6;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <Breadcrumbs client:load crumbs={[
        { label: 'Accueil', href: '/' },
        { label: 'Jardiniers', href: '/classement' },
        { label: prest?.ville ? `${fullName} — ${prest.ville}` : fullName },
      ]} />
    </div>
  </div>

  {!user ? (
    <div style="display:flex;align-items:center;justify-content:center;min-height:60vh">
      <p style="color:#9ca3af">Profil introuvable.</p>
    </div>
  ) : (
  <div class="profile-page">

    <div class="hero-cover"></div>

    <div class="container">

      <!-- PROFILE HEADER -->
      <div class="profile-header">
        <div class="profile-avatar">
          <img src={avatarSrc} alt={fullName} />
        </div>

        <div class="profile-meta">
          <div class="profile-name-row">
            <h1>{fullName}</h1>
            <span class="badge-verified">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Vérifié
            </span>
          </div>

          <p class="profile-ville">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {prest?.ville}
          </p>

          {(prest?.numberOfReviews ?? 0) > 0 && (
            <div class="profile-rating">
              <span class="stars-full">{'★'.repeat(starsArr(prest?.averageRating ?? 0).full)}</span>
              <span class="stars-empty">{'★'.repeat(starsArr(prest?.averageRating ?? 0).empty)}</span>
              <span class="rating-score">{(prest?.averageRating ?? 0).toFixed(1)}</span>
              <span class="rating-count">({prest?.numberOfReviews} avis)</span>
            </div>
          )}

          <div class="trust-badges">
            {prest?.isEntrepreneur && (
              <span class="trust-badge">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                Professionnel
              </span>
            )}
            {prest?.materielOK && (
              <span class="trust-badge">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                Materiel inclus
              </span>
            )}
            {prest?.qualifElagage && (
              <span class="trust-badge">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                Qualifié élagage
              </span>
            )}
            <span class="trust-badge trust-badge--muted">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Membre depuis {memberSince}
            </span>
          </div>
        </div>

        {prest?.tarifHoraire && (
          <div class="tarif-badge">
            <span class="tarif-val">{prest.tarifHoraire} €</span>
            <span class="tarif-unit">/ heure</span>
          </div>
        )}
      </div>

      <!-- BODY -->
      <div class="profile-body">

        <div class="profile-content">

          {prest?.description && (
            <div class="content-card">
              <h2>Présentation</h2>
              <p class="description-text">{prest.description}</p>
            </div>
          )}

          <div class="content-card">
            <h2>Services proposés</h2>
            <div class="services-grid">
              {prest?.prestations?.map((p: string) => (
                <div class="service-item">
                  <div class="service-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <span>{catName(p)}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="content-card">
            <h2>Informations</h2>
            <div class="info-grid">
              <div class="info-item">
                <span class="info-label">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  Zone d'intervention
                </span>
                <span class="info-val">{prest?.ville} et alentours</span>
              </div>
              {prest?.tarifHoraire && (
                <div class="info-item">
                  <span class="info-label">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    Tarif horaire
                  </span>
                  <span class="info-val">{prest.tarifHoraire} €/h</span>
                </div>
              )}
              {user.telephone && (
                <div class="info-item">
                  <span class="info-label">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    Téléphone
                  </span>
                  <span class="info-val">{user.telephone}</span>
                </div>
              )}
              <div class="info-item">
                <span class="info-label">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  Membre depuis
                </span>
                <span class="info-val">{memberSince}</span>
              </div>
            </div>
          </div>

          {totalReviews > 0 && (
            <div class="content-card">
              <h2>Avis clients ({totalReviews})</h2>

              {/* Moyennes globales par catégorie */}
              {categoryAverages.length > 0 && (
                <div class="cat-averages">
                  {categoryAverages.map((c) => (
                    <div class="cat-row" key={c.key}>
                      <span class="cat-label">{c.label}</span>
                      <div class="cat-bar-wrap">
                        <div class="cat-bar" style={`width:${c.pct}%`}></div>
                      </div>
                      <span class="cat-val">{c.avg.toFixed(1)}</span>
                    </div>
                  ))}
                </div>
              )}

              <div class="reviews-list">
                {processedReviews.map((r) => (
                  <div class="review-card">
                    <div class="review-header">
                      <div class="review-avatar">{r.initial}</div>
                      <div class="review-meta">
                        <div class="review-author">{r.author}</div>
                        <div class="review-date">{r.date}</div>
                      </div>
                      <div class="review-stars">
                        <span class="stars-full">{r.starsFullStr}</span>
                        <span class="stars-empty">{r.starsEmptyStr}</span>
                        <span class="review-score">{r.avgStr}</span>
                      </div>
                    </div>
                    {r.recommend && (
                      <div class="review-recommend">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        Recommande ce prestataire
                      </div>
                    )}
                    {r.details.length > 0 && (
                      <div class="review-details">
                        {r.details.map((d) => (
                          <div class="rd-row" key={d.key}>
                            <span class="rd-label">{d.label}</span>
                            <div class="rd-bar-wrap"><div class="rd-bar" style={`width:${d.pct}%`}></div></div>
                            <span class="rd-val">{d.val}/5</span>
                          </div>
                        ))}
                      </div>
                    )}
                    {r.comment && <p class="review-text">{r.comment}</p>}
                  </div>
                ))}
              </div>
            </div>
          )}

        </div>

        <aside class="booking-aside">
          <BookingWidget
            client:load
            prestataireId={id}
            prenom={user.prenom}
            tarifHoraire={prest?.tarifHoraire}
            averageRating={prest?.averageRating}
            numberOfReviews={prest?.numberOfReviews}
            prestations={prest?.prestations ?? []}
          />
        </aside>

      </div>
    </div>
  </div>
  )}

  <Footer />
</BaseLayout>

<style>
* { box-sizing: border-box; }

.profile-page { background: #f2efe6; min-height: 100vh; }

.hero-cover {
  height: 180px;
  background: linear-gradient(135deg, #141f0b 0%, #1e3015 40%, #2d4a1a 70%, #3a5020 100%);
  position: relative;
}
.hero-cover::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(
    45deg,
    rgba(255,255,255,0.03) 0px,
    rgba(255,255,255,0.03) 1px,
    transparent 1px,
    transparent 12px
  );
}

.container { max-width: 1100px; margin: 0 auto; padding: 0 2rem 5rem; }

/* PROFILE HEADER */
.profile-header {
  display: flex;
  align-items: flex-end;
  gap: 1.5rem;
  margin-top: -56px;
  margin-bottom: 2rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid #e2dece;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}

.profile-avatar {
  width: 112px;
  height: 112px;
  border-radius: 50%;
  overflow: hidden;
  border: 4px solid #f2efe6;
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  flex-shrink: 0;
  background: linear-gradient(135deg, #dde6c8, #a8c47a);
}
.profile-avatar img { width: 100%; height: 100%; object-fit: cover; }

.profile-meta { flex: 1; min-width: 220px; padding-top: 60px; }

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 0.25rem;
  flex-wrap: wrap;
}
.profile-page h1 {
  font-size: 1.7rem;
  font-weight: 900;
  color: #1a1a0e;
  margin: 0;
  letter-spacing: -0.025em;
}

.badge-verified {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.7rem;
  font-weight: 700;
  color: #3a5020;
  background: rgba(81,95,55,0.1);
  border: 1px solid rgba(81,95,55,0.22);
  padding: 0.18rem 0.55rem;
  border-radius: 999px;
}

.profile-ville {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  color: #6b7280;
  font-size: 0.85rem;
  margin-bottom: 0.4rem;
}

.profile-rating {
  display: flex;
  align-items: center;
  gap: 0.2rem;
  font-size: 0.875rem;
  margin-bottom: 0.6rem;
}
.stars-full { color: #e6c553; }
.stars-empty { color: #ddd8c8; }
.rating-score { font-weight: 700; color: #1a1a0e; margin-left: 0.1rem; }
.rating-count { color: #9ca3af; font-size: 0.78rem; margin-left: 0.1rem; }

.trust-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
  margin-top: 0.4rem;
}
.trust-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.28rem;
  font-size: 0.7rem;
  font-weight: 600;
  color: #3a5020;
  background: rgba(81,95,55,0.08);
  border: 1px solid rgba(81,95,55,0.18);
  padding: 0.18rem 0.55rem;
  border-radius: 999px;
}
.trust-badge--muted {
  color: #8a8070;
  background: rgba(0,0,0,0.04);
  border-color: rgba(0,0,0,0.08);
}

.tarif-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #3a5020;
  color: #fff;
  padding: 0.875rem 1.375rem;
  border-radius: 16px;
  flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(58,80,32,0.28);
  margin-bottom: 0.25rem;
}
.tarif-val { font-size: 1.6rem; font-weight: 900; line-height: 1; color: #a8c47a; }
.tarif-unit { font-size: 0.7rem; color: rgba(255,255,255,0.55); margin-top: 0.2rem; }

/* BODY LAYOUT */
.profile-body {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 2rem;
  align-items: start;
}

/* CONTENT CARDS */
.content-card {
  background: #FCFAF5;
  border: 1px solid #e9e5d6;
  border-radius: 16px;
  padding: 1.5rem;
  margin-bottom: 1.25rem;
}
.content-card h2 {
  font-size: 0.68rem;
  font-weight: 800;
  color: #515F37;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin: 0 0 1rem;
  padding-bottom: 0.625rem;
  border-bottom: 1px solid #e9e5d6;
}

.description-text {
  color: #374151;
  font-size: 0.92rem;
  line-height: 1.8;
  white-space: pre-wrap;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 0.5rem;
}
.service-item {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  padding: 0.55rem 0.75rem;
  background: #f5f2eb;
  border: 1px solid #e4e0d0;
  border-radius: 10px;
  font-size: 0.85rem;
  color: #374151;
}
.service-icon {
  width: 26px;
  height: 26px;
  background: rgba(81,95,55,0.1);
  color: #3a5020;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.info-grid { display: flex; flex-direction: column; }
.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.7rem 0;
  border-bottom: 1px solid #f0ede3;
  gap: 1rem;
}
.info-item:last-child { border-bottom: none; }
.info-label {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.85rem;
  color: #9ca3af;
}
.info-label svg { flex-shrink: 0; }
.info-val {
  font-size: 0.875rem;
  font-weight: 600;
  color: #1a1a0e;
  text-align: right;
}

/* REVIEWS */
/* Category averages */
.cat-averages {
  display: flex; flex-direction: column; gap: 0.5rem;
  margin-bottom: 1.25rem; padding-bottom: 1.25rem;
  border-bottom: 1px solid #e9e5d6;
}
.cat-row { display: flex; align-items: center; gap: 0.75rem; }
.cat-label { font-size: 0.75rem; color: #6b7280; width: 130px; flex-shrink: 0; }
.cat-bar-wrap { flex: 1; height: 6px; background: #e9e5d6; border-radius: 999px; overflow: hidden; }
.cat-bar { height: 100%; background: linear-gradient(90deg, #3a5020, #a8c47a); border-radius: 999px; transition: width 0.6s ease; }
.cat-val { font-size: 0.75rem; font-weight: 700; color: #3a5020; width: 28px; text-align: right; flex-shrink: 0; }

/* Review detail bars */
.review-recommend {
  display: flex; align-items: center; gap: 0.3rem;
  font-size: 0.75rem; font-weight: 600; color: #3a5020;
  margin-bottom: 0.5rem;
}
.review-recommend svg { color: #3a5020; }
.review-details {
  display: flex; flex-direction: column; gap: 0.3rem;
  margin-bottom: 0.625rem;
  background: #f5f2eb; border-radius: 8px; padding: 0.625rem 0.75rem;
}
.rd-row { display: flex; align-items: center; gap: 0.5rem; }
.rd-label { font-size: 0.68rem; color: #9ca3af; width: 110px; flex-shrink: 0; }
.rd-bar-wrap { flex: 1; height: 4px; background: #e2dece; border-radius: 999px; overflow: hidden; }
.rd-bar { height: 100%; background: #3a5020; border-radius: 999px; }
.rd-val { font-size: 0.68rem; font-weight: 700; color: #515F37; width: 28px; text-align: right; flex-shrink: 0; }

