---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/astro/Navbar.astro';
import Footer from '../../components/astro/Footer.astro';
import PrestataireProfile from '../../components/vue/PrestataireProfile.vue';

const { id } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3002/api';

interface User {
  _id: string; nom: string; prenom: string; ville: string;
  prestations: string[]; description?: string; tarifHoraire?: number;
  averageRating: number; numberOfReviews: number;
  profil_image?: { secure_url: string };
}

let user: User | null = null;
try {
  const res = await fetch(`${API_URL}/users/${id}`);
  if (res.ok) {
    const data = await res.json() as { user: User };
    user = data.user;
  }
} catch { /* non-bloquant */ }

if (!user) return Astro.redirect('/recherche');

const title = `${user.prenom} ${user.nom} — Jardinier à ${user.ville}`;
const description = user.description ?? `${user.prenom} ${user.nom}, jardinier professionnel à ${user.ville}. Services : ${user.prestations.join(', ')}.`;
---
<BaseLayout title={title} description={description} ogImage={user.profil_image?.secure_url}>
  <Navbar />
  <main>
    <PrestataireProfile client:load prestataireId={id!} />
  </main>
  <Footer />
</BaseLayout>
