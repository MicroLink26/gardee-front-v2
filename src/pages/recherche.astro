---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
import SearchResults from '../components/vue/SearchResults.vue';

const q = Astro.url.searchParams.get('q') ?? '';
---
<BaseLayout
  title={q ? `"${q}" — Jardiniers` : 'Rechercher un jardinier'}
  description="Trouvez un jardinier professionnel près de chez vous."
>
  <Navbar />

  <div class="page-header">
    <div class="page-header-inner">
      <h1>{q ? `Jardiniers pour "${q}"` : 'Tous les jardiniers'}</h1>
      <p>Des professionnels vérifiés, disponibles près de chez vous</p>
    </div>
  </div>

  <main class="page-content">
    <SearchResults client:load initialQuery={q} />
  </main>

  <Footer />
</BaseLayout>

<style>
.page-header {
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
  border-bottom: 1px solid #d1fae5;
  padding: 2.5rem 2rem;
}
.page-header-inner {
  max-width: 1100px;
  margin: 0 auto;
}
.page-header h1 {
  font-size: 1.75rem;
  font-weight: 800;
  color: #111827;
  margin: 0 0 0.35rem;
}
.page-header p {
  color: #6b7280;
  font-size: 0.95rem;
  margin: 0;
}
.page-content { min-height: 60vh; }
</style>
