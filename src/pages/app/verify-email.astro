---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailVerificationScreen from '../../components/vue/EmailVerificationScreen.vue';

// Hash params are client-side only, pass empty and let Vue read them
const redirect = Astro.url.searchParams.get('redirect') ?? '/app/login';
---
<BaseLayout title="Vérifier votre email" noindex={true}>
  <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #f5f2eb;">
    <EmailVerificationScreen
      client:load
      redirect={redirect}
    />
  </div>
</BaseLayout>
