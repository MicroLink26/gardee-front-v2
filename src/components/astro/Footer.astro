---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer-top">
    <div class="footer-top-inner">
      <div class="footer-tagline">
        <span>Votre jardin mérite le meilleur</span>
      </div>
      <div class="footer-top-actions">
        <a href="/carte" class="footer-cta">Trouver un jardinier</a>
        <a href="/postuler" class="footer-cta footer-cta--outline">Devenir prestataire</a>
      </div>
    </div>
  </div>

  <div class="newsletter-section">
    <div class="newsletter-content">
      <h3>Restez informé 📬</h3>
      <p>Recevez chaque semaine les top prestataires et conseils d'entretien</p>
      <form id="newsletter-form" class="newsletter-form">
        <input
          type="email"
          placeholder="Votre email..."
          required
          class="newsletter-input"
        />
        <button type="submit" class="newsletter-btn">S'abonner</button>
      </form>
      <p class="newsletter-info">Sans spam, désinscription facile</p>
    </div>
  </div>

  <div class="footer-inner">

    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <svg viewBox="0 0 32 32" fill="none" width="28" height="28">
          <path d="M16 3C16 3 6 10 6 19a10 10 0 0020 0C26 10 16 3 16 3z" fill="#5f7a39" opacity="0.8"/>
          <path d="M16 8C16 8 10 13 10 19a6 6 0 0012 0C22 13 16 8 16 8z" fill="#a8c47a"/>
        </svg>
        GARDEE
      </a>
      <p>La plateforme qui connecte les particuliers avec des jardiniers professionnels vérifiés.</p>
      <div class="footer-badges">
        <button class="fbadge fbadge--pwa" id="footer-pwa-btn" style="display:none">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <div><span class="fbadge-sub">Installer</span><span class="fbadge-main">l'application</span></div>
        </button>
        <span class="fbadge fbadge--soon" title="Bientôt disponible">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M3.18 23.76a2 2 0 001.93-.21l11.44-6.6-2.77-2.77-10.6 9.58zM.5 1.1C.19 1.45 0 1.96 0 2.62v18.76c0 .66.19 1.17.5 1.52l.08.08 10.5-10.5v-.25L.58 1.03.5 1.1zM20.55 10.3l-2.88-1.66-3.1 3.1 3.1 3.1 2.9-1.67c.83-.48.83-1.4-.02-1.87zM5.11.45L16.55 7.05l-2.77 2.77L3.18.25A2 2 0 015.1.45z"/></svg>
          <div><span class="fbadge-sub">Bientôt sur</span><span class="fbadge-main">Google Play</span></div>
        </span>
        <span class="fbadge fbadge--soon" title="Bientôt disponible">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98l-.09.06c-.22.15-2.18 1.27-2.16 3.8.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.37 2.78M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <div><span class="fbadge-sub">Bientôt sur</span><span class="fbadge-main">App Store</span></div>
        </span>
      </div>
    </div>

    <div class="footer-col">
      <h4>Trouver</h4>
      <a href="/recherche">Jardiniers près de moi</a>
      <a href="/classement">Classement</a>
      <a href="/carte">Carte interactive</a>
    </div>

    <div class="footer-col">
      <h4>Rejoindre</h4>
      <a href="/postuler">Devenir prestataire</a>
      <a href="/app/login">Mon espace</a>
    </div>

    <div class="footer-col">
      <h4>Informations</h4>
      <a href="/contact">Contact</a>
      <a href="/mentions-legales">Mentions légales</a>
    </div>

  </div>

  <div class="footer-bottom">
    <p>© {year} Gardee — Tous droits réservés</p>
    <div class="footer-bottom-links">
      <a href="/mentions-legales">Mentions légales</a>
      <a href="/contact">Contact</a>
      <span id="status-indicator" class="status-badge" title="Statut connexion">🟢 Online</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0f1a0a;
  }

  /* ── TOP BAND ── */
  .footer-top {
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 2.5rem 0;
  }
  .footer-top-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .footer-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 800;
    color: rgba(255,255,255,0.85);
    letter-spacing: -0.02em;
  }
  .footer-top-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .footer-cta {
    padding: 0.65rem 1.4rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
    background: #515F37;
    color: #fff;
    border: 1.5px solid #515F37;
  }
  .footer-cta:hover { background: #3d4a28; border-color: #3d4a28; }
  .footer-cta--outline {
    background: transparent;
    color: rgba(255,255,255,0.75);
    border-color: rgba(255,255,255,0.2);
  }
  .footer-cta--outline:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.35); color: #fff; }

  /* ── MAIN GRID ── */
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
    color: #a8c47a;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-decoration: none;
  }
  .footer-brand p {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.65;
    max-width: 240px;
    margin-bottom: 1.25rem;
  }

  .footer-badges { display: flex; flex-direction: column; gap: 0.45rem; }
  .fbadge {
    display: inline-flex; align-items: center; gap: 0.55rem;
    padding: 0.45rem 0.75rem;
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.85);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px; text-decoration: none; cursor: pointer;
    transition: background 0.15s, border-color 0.15s; width: fit-content;
  }
  .fbadge:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); }
  .fbadge--pwa { background: rgba(81,95,55,0.4); border-color: rgba(81,95,55,0.6); }
  .fbadge--pwa:hover { background: rgba(81,95,55,0.6); }
  .fbadge--soon {
    background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.08); opacity: 0.7; cursor: not-allowed;
  }
  .fbadge--soon:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.08); }
  .fbadge-sub { display: block; font-size: 0.58rem; opacity: 0.65; line-height: 1; }
  .fbadge-main { display: block; font-size: 0.78rem; font-weight: 700; line-height: 1.3; }

  .footer-col { display: flex; flex-direction: column; gap: 0.55rem; }
  .footer-col h4 {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.35rem;
  }
  .footer-col a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s;
    width: fit-content;
  }
  .footer-col a:hover { color: #a8c47a; }

  /* ── BOTTOM ── */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 1.25rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
  }
  .footer-bottom-links { display: flex; gap: 1.5rem; }
  .footer-bottom-links a {
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-bottom-links a:hover { color: rgba(255,255,255,0.6); }

  .status-badge {
    display: none;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.6);
    padding: 0.25rem 0.5rem;
  }
  .status-badge.offline {
    display: inline-flex;
    color: #fca5a5;
  }

  .newsletter-section {
    background: linear-gradient(135deg, rgba(95, 122, 57, 0.15) 0%, rgba(168, 196, 122, 0.08) 100%);
    border-top: 1px solid rgba(168, 196, 122, 0.2);
    border-bottom: 1px solid rgba(168, 196, 122, 0.2);
    padding: 2.5rem;
  }
  .newsletter-content {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
  }
  .newsletter-section h3 {
    font-size: 1.3rem;
    font-weight: 800;
    color: rgba(255,255,255,0.95);
    margin: 0 0 0.5rem;
  }
  .newsletter-section p {
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    margin: 0;
  }
  .newsletter-info {
    font-size: 0.75rem !important;
    color: rgba(255,255,255,0.5) !important;
    margin-top: 0.75rem !important;
  }
  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    width: fit-content;
  }
  .newsletter-input {
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    color: #fff;
    font-size: 0.9rem;
    min-width: 250px;
  }
  .newsletter-input::placeholder {
    color: rgba(255,255,255,0.5);
  }
  .newsletter-input:focus {
    outline: none;
    border-color: rgba(168, 196, 122, 0.6);
    background: rgba(255,255,255,0.15);
  }
  .newsletter-btn {
    padding: 0.75rem 1.5rem;
    background: #a8c47a;
    color: #0f1a0a;
    border: none;
    border-radius: 8px;
    font-weight: 800;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .newsletter-btn:hover {
    background: #bfd499;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .newsletter-section { padding: 1.5rem; }
    .newsletter-content { grid-template-columns: 1fr; gap: 1rem; }
    .newsletter-section h3 { font-size: 1.1rem; }
    .newsletter-section p { font-size: 0.85rem; }
    .newsletter-form { width: 100%; gap: 0.4rem; }
    .newsletter-input {
      min-width: 100%;
      padding: 0.65rem 0.75rem;
      font-size: 16px; /* Prevents zoom on iOS */
    }
    .newsletter-btn {
      padding: 0.65rem 1rem;
      font-size: 0.85rem;
      white-space: nowrap;
      flex-shrink: 0;
    }
  }

  @media (max-width: 480px) {
    .newsletter-section { padding: 1.25rem; }
    .newsletter-section h3 { font-size: 1rem; margin: 0 0 0.4rem; }
    .newsletter-section p { font-size: 0.8rem; }
    .newsletter-form { flex-direction: column; }
    .newsletter-input { min-width: 100%; }
    .newsletter-btn { width: 100%; }
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
    .footer-badges { flex-direction: row; flex-wrap: wrap; }
    .footer-top-inner { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; }
  }
</style>

<script>
  const footerBtn = document.getElementById('footer-pwa-btn');
  const statusIndicator = document.getElementById('status-indicator');
  let prompt: any = null;

  // PWA install prompt
  window.addEventListener('beforeinstallprompt', (e) => {
    prompt = e;
    if (footerBtn) footerBtn.style.display = 'inline-flex';
  });

  footerBtn?.addEventListener('click', async () => {
    if (!prompt) return;
    prompt.prompt();
    const { outcome } = await prompt.userChoice;
    if (outcome === 'accepted' && footerBtn) footerBtn.style.display = 'none';
    prompt = null;
  });

  window.addEventListener('appinstalled', () => {
    if (footerBtn) footerBtn.style.display = 'none';
  });

  // Online/Offline indicator (show only offline)
  function updateStatus() {
    if (statusIndicator) {
      if (!navigator.onLine) {
        statusIndicator.textContent = '🔴 Offline';
        statusIndicator.classList.add('offline');
      } else {
        statusIndicator.classList.remove('offline');
      }
    }
  }

  updateStatus();
  window.addEventListener('online', updateStatus);
  window.addEventListener('offline', updateStatus);

  // Newsletter signup
  const form = document.getElementById('newsletter-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = form.querySelector('input[type="email"]').value;
      const btn = form.querySelector('button');
      const originalText = btn.textContent;

      btn.textContent = 'Inscription...';
      btn.disabled = true;

      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();

        if (res.ok) {
          btn.textContent = '✓ Abonné!';
          form.reset();
          setTimeout(() => {
            btn.textContent = originalText;
            btn.disabled = false;
          }, 3000);
        } else {
          btn.textContent = '✗ Erreur';
          setTimeout(() => {
            btn.textContent = originalText;
            btn.disabled = false;
          }, 2000);
        }
      } catch (err) {
        btn.textContent = '✗ Erreur';
        setTimeout(() => {
          btn.textContent = originalText;
          btn.disabled = false;
        }, 2000);
      }
    });
  }
</script>
