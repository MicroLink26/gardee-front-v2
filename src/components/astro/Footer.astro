---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer-inner">

    <div class="footer-brand">
      <img src="/logo.png" alt="Gardee" height="40" />
      <p>La plateforme qui connecte les particuliers avec des jardiniers professionnels vérifiés.</p>
      <div class="footer-badges">
        <button class="fbadge fbadge--pwa" id="footer-pwa-btn" style="display:none">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <div><span class="fbadge-sub">Installer</span><span class="fbadge-main">l'application</span></div>
        </button>
        <a href="#" class="fbadge" title="Bientôt sur Google Play">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M3.18 23.76a2 2 0 001.93-.21l11.44-6.6-2.77-2.77-10.6 9.58zM.5 1.1C.19 1.45 0 1.96 0 2.62v18.76c0 .66.19 1.17.5 1.52l.08.08 10.5-10.5v-.25L.58 1.03.5 1.1zM20.55 10.3l-2.88-1.66-3.1 3.1 3.1 3.1 2.9-1.67c.83-.48.83-1.4-.02-1.87zM5.11.45L16.55 7.05l-2.77 2.77L3.18.25A2 2 0 015.1.45z"/></svg>
          <div><span class="fbadge-sub">Disponible sur</span><span class="fbadge-main">Google Play</span></div>
        </a>
        <a href="#" class="fbadge" title="Bientôt sur l'App Store">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98l-.09.06c-.22.15-2.18 1.27-2.16 3.8.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.37 2.78M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <div><span class="fbadge-sub">Télécharger sur</span><span class="fbadge-main">l'App Store</span></div>
        </a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Trouver</h4>
      <a href="/recherche">Jardiniers près de moi</a>
      <a href="/classement">Classement</a>
      <a href="/carte">Carte interactive</a>
    </div>

    <div class="footer-col">
      <h4>Rejoindre</h4>
      <a href="/postuler">Devenir prestataire</a>
      <a href="/app/login">Mon espace</a>
    </div>

    <div class="footer-col">
      <h4>Informations</h4>
      <a href="/contact">Contact</a>
      <a href="/faq">FAQ</a>
      <a href="/mentions-legales">Mentions légales</a>
    </div>

  </div>

  <div class="footer-bottom">
    <p>© {year} Gardee — Tous droits réservés</p>
  </div>
</footer>

<style>
  .footer {
    background: #111827;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  .footer-brand img { display: block; margin-bottom: 0.875rem; background: #d6cda4; border-radius: 6px; padding: 4px 8px; }
  .footer-brand p {
    font-size: 0.875rem;
    color: #9ca3af;
    line-height: 1.6;
    max-width: 240px;
    margin-bottom: 1rem;
  }
  .footer-badges { display: flex; flex-direction: column; gap: 0.5rem; }
  .fbadge {
    display: inline-flex; align-items: center; gap: 0.55rem;
    padding: 0.45rem 0.75rem;
    background: #1f2937; color: #fff;
    border-radius: 8px; text-decoration: none; border: none; cursor: pointer;
    transition: background 0.15s; width: fit-content;
  }
  .fbadge:hover { background: #374151; }
  .fbadge--pwa { background: #515F37; }
  .fbadge--pwa:hover { background: #3d4a28; }
  .fbadge-sub { display: block; font-size: 0.58rem; opacity: 0.75; line-height: 1; }
  .fbadge-main { display: block; font-size: 0.8rem; font-weight: 700; line-height: 1.3; }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-col h4 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f9fafb;
    margin-bottom: 0.25rem;
  }
  .footer-col a {
    color: #d1d5db;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: #fff; }

  .footer-bottom {
    border-top: 1px solid #374151;
    padding: 1.25rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
    font-size: 0.8rem;
    color: #9ca3af;
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
    .footer-badges { flex-direction: row; flex-wrap: wrap; }
  }
  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>

<script>
  const footerBtn = document.getElementById('footer-pwa-btn');
  let prompt: any = null;

  window.addEventListener('beforeinstallprompt', (e) => {
    prompt = e;
    if (footerBtn) footerBtn.style.display = 'inline-flex';
  });

  footerBtn?.addEventListener('click', async () => {
    if (!prompt) return;
    prompt.prompt();
    const { outcome } = await prompt.userChoice;
    if (outcome === 'accepted' && footerBtn) footerBtn.style.display = 'none';
    prompt = null;
  });

  window.addEventListener('appinstalled', () => {
    if (footerBtn) footerBtn.style.display = 'none';
  });
</script>
