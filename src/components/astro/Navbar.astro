---
import OptimizedImage from './OptimizedImage.astro';

const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath.startsWith(path) ? 'nav-active' : '';
const isExact = (path: string) => currentPath === path ? 'nav-active' : '';
---
<nav class="navbar">
  <!-- Logo -->
  <div class="navbar-brand">
    <a href="/">
      <OptimizedImage src="/img/logo.png" alt="Gardee" height="40" style="display:block;object-fit:contain;" />
    </a>
  </div>

  <!-- Centre -->
  <ul class="navbar-links">
    <li><a href="/" class={isExact('/')}>Accueil</a></li>

    <!-- Dropdown "Recherchez un jardinier" -->
    <li class="has-dropdown">
      <button class={`dropdown-trigger${currentPath.startsWith('/carte') || currentPath.startsWith('/classement') ? ' nav-active' : ''}`} aria-haspopup="true" aria-expanded="false">
        Recherchez un jardinier
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="dropdown-menu" role="menu">
        <a href="/carte" class="dropdown-item" role="menuitem">
          <span class="dropdown-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
          </span>
          <span>
            <strong>Jardiniers près de chez moi</strong>
            <small>Carte interactive</small>
          </span>
        </a>
        <a href="/classement" class="dropdown-item" role="menuitem">
          <span class="dropdown-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
          </span>
          <span>
            <strong>Classement des jardiniers</strong>
            <small>Top jardiniers notés</small>
          </span>
        </a>
      </div>
    </li>

    <li><a href="/postuler" class={isActive('/postuler')}>Devenir prestataire</a></li>
    <li><a href="/contact" class={isActive('/contact')}>Contact</a></li>
  </ul>

  <!-- Auth + Lang -->
  <div class="navbar-auth">
    <button class="btn-lang" id="lang-btn" aria-label="Langue / Language">
      <span id="lang-label">FR</span>
    </button>
    <a href="/app/login" class="btn-signin" id="nav-auth-btn">Se connecter</a>
  </div>

  <button class="burger" id="burger-btn" aria-label="Menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile overlay menu -->
<div class="mobile-overlay" id="mobile-overlay">
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-header">
      <OptimizedImage src="/img/logo.png" alt="Gardee" height="36" />
      <button class="mobile-close" id="mobile-close" aria-label="Fermer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <nav class="mobile-nav">
      <a href="/" class={currentPath === '/' ? 'mobile-link mobile-link--active' : 'mobile-link'}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Accueil
      </a>
      <a href="/carte" class={currentPath.startsWith('/carte') ? 'mobile-link mobile-link--active' : 'mobile-link'}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
        Jardiniers près de chez moi
      </a>
      <a href="/classement" class={currentPath.startsWith('/classement') ? 'mobile-link mobile-link--active' : 'mobile-link'}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
        Classement des jardiniers
      </a>
      <a href="/postuler" class={currentPath.startsWith('/postuler') ? 'mobile-link mobile-link--active' : 'mobile-link'}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
        Devenir prestataire
      </a>
      <a href="/contact" class={currentPath.startsWith('/contact') ? 'mobile-link mobile-link--active' : 'mobile-link'}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        Contact
      </a>
    </nav>
    <a href="/app/login" class="mobile-signin" id="mobile-auth-btn">Se connecter</a>
  </div>
</div>

<script>
  // ── Language toggle ──────────────────────────────────────────────
  const TRANSLATIONS: Record<string, Record<string, string>> = {
    en: {
      'Accueil': 'Home',
      'Recherchez un jardinier': 'Find a gardener',
      'Jardiniers près de chez moi': 'Gardeners near me',
      'Classement des jardiniers': 'Gardener ranking',
      'Devenir prestataire': 'Become a provider',
      'Contact': 'Contact',
      'Se connecter': 'Log in',
      'Mon espace': 'My space',
    },
  };

  let currentLang = (localStorage.getItem('gardee-lang') ?? 'fr') as 'fr' | 'en';

  function applyLang(lang: 'fr' | 'en') {
    currentLang = lang;
    localStorage.setItem('gardee-lang', lang);
    const label = document.getElementById('lang-label');
    if (label) label.textContent = lang.toUpperCase();
    document.documentElement.lang = lang;

    if (lang === 'en') {
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        if (TRANSLATIONS.en[key]) el.textContent = TRANSLATIONS.en[key];
      });
    } else {
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        el.textContent = key;
      });
    }
  }

  // Tag nav items with data-i18n
  document.querySelectorAll('.navbar-links a, .dropdown-trigger, .dropdown-item strong, .mobile-link span:not(.tab-count), .mobile-signin').forEach(el => {
    const text = (el.textContent ?? '').trim();
    if (TRANSLATIONS.en[text]) el.setAttribute('data-i18n', text);
  });

  applyLang(currentLang);

  document.getElementById('lang-btn')?.addEventListener('click', () => {
    applyLang(currentLang === 'fr' ? 'en' : 'fr');
  });

  // Auth button: update to "Mon espace" if logged in (reads persisted Pinia token)
  function updateAuthButton() {
    try {
      const raw = localStorage.getItem('gardee-auth');
      if (raw) {
        const { accessToken } = JSON.parse(raw);
        if (accessToken) {
          const navBtn = document.getElementById('nav-auth-btn');
          const mobBtn = document.getElementById('mobile-auth-btn');
          if (navBtn) { navBtn.textContent = 'Mon espace'; navBtn.href = '/app/dashboard'; }
          if (mobBtn) { mobBtn.textContent = 'Mon espace'; mobBtn.href = '/app/dashboard'; }
        }
      }
    } catch { /* non bloquant */ }
  }
  updateAuthButton();

  // Dropdown
  const dropdownTrigger = document.querySelector('.dropdown-trigger');
  const dropdownMenu = document.querySelector('.dropdown-menu');

  function closeDropdown() {
    dropdownMenu?.classList.remove('open');
    dropdownTrigger?.setAttribute('aria-expanded', 'false');
  }

  dropdownTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdownMenu?.classList.contains('open');
    if (isOpen) {
      closeDropdown();
    } else {
      dropdownMenu?.classList.add('open');
      dropdownTrigger.setAttribute('aria-expanded', 'true');
    }
  });

  document.addEventListener('click', closeDropdown);
  dropdownMenu?.addEventListener('click', (e) => e.stopPropagation());

  // Burger / mobile menu
  const burgerBtn = document.getElementById('burger-btn');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('mobile-close');

  function openMenu() {
    if (!overlay) return;
    overlay.style.display = 'block';
    overlay.offsetHeight;
    overlay.classList.add('open');
    burgerBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    if (!overlay) return;
    overlay.classList.remove('open');
    burgerBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    overlay.addEventListener('transitionend', () => {
      overlay.style.display = 'none';
    }, { once: true });
  }

  burgerBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeMenu();
  });

  // Scroll effect
  function handleScroll() {
    const navbar = document.querySelector('.navbar');
    if (!navbar) return;
    navbar.classList.toggle('scrolled', window.scrollY > 20);
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2.5rem;
    height: 60px;
    background: rgba(252,250,245,0.92);
    border-bottom: 1px solid rgba(81,95,55,0.08);
    position: sticky;
    top: 0;
    z-index: 200;
    transition: background 0.2s, box-shadow 0.2s;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .navbar.scrolled {
    background: rgba(252,250,245,0.98);
    box-shadow: 0 2px 20px rgba(81,95,55,0.08);
    border-bottom-color: rgba(81,95,55,0.12);
  }

  .navbar-brand { flex-shrink: 0; }

  .navbar-links {
    display: flex;
    list-style: none;
    gap: 0.125rem;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .navbar-links a, .dropdown-trigger {
    display: block;
    text-decoration: none;
    color: #4b5328;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.45rem 0.875rem;
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .navbar-links a:hover, .dropdown-trigger:hover { background: rgba(81,95,55,0.07); color: #515F37; }
  .nav-active {
    color: #515F37 !important;
    font-weight: 700;
    background: rgba(81,95,55,0.08) !important;
  }

  /* Dropdown */
  .has-dropdown { position: relative; }
  .dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    white-space: nowrap;
  }
  .dropdown-trigger svg { transition: transform 0.2s; }
  .dropdown-trigger[aria-expanded="true"] svg { transform: rotate(180deg); }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: 280px;
    background: #FCFAF5;
    border: 1.5px solid #e9e5d6;
    border-radius: 14px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    padding: 0.5rem;
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    z-index: 300;
  }
  .dropdown-menu.open { display: flex; }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.875rem;
    border-radius: 10px;
    text-decoration: none;
    color: #374151;
    transition: background 0.15s;
  }
  .dropdown-item:hover { background: #f0ede3; }
  .dropdown-icon {
    width: 36px; height: 36px;
    background: rgba(81,95,55,0.08);
    color: #515F37;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .dropdown-icon svg { width: 16px; height: 16px; }
  .dropdown-item span:last-child { display: flex; flex-direction: column; gap: 0.1rem; }
  .dropdown-item strong { font-size: 0.85rem; color: #1a1a0e; font-weight: 700; }
  .dropdown-item small { font-size: 0.73rem; color: #9ca3af; }

  /* Lang button */
  .btn-lang {
    padding: 0.35rem 0.65rem;
    border: 1.5px solid rgba(81,95,55,0.25);
    border-radius: 7px;
    background: transparent; color: #515F37;
    font-size: 0.75rem; font-weight: 800;
    cursor: pointer; font-family: inherit;
    letter-spacing: 0.05em;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-lang:hover { background: rgba(81,95,55,0.07); border-color: rgba(81,95,55,0.45); }

  /* Auth button */
  .btn-signin {
    padding: 0.45rem 1.1rem;
    border: 1.5px solid rgba(81,95,55,0.4);
    border-radius: 8px;
    color: #515F37;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    background: transparent;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .btn-signin:hover {
    background: #515F37;
    color: #fff;
    border-color: #515F37;
  }

  /* Burger */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px; height: 36px;
    background: none; border: none; cursor: pointer;
    padding: 4px; border-radius: 8px;
    transition: background 0.15s;
  }
  .burger:hover { background: rgba(81,95,55,0.08); }
  .burger span {
    display: block; width: 100%; height: 2px;
    background: #515F37; border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* Mobile overlay */
  .mobile-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(26,26,14,0.5);
    z-index: 500;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s;
  }
  .mobile-overlay.open { opacity: 1; pointer-events: auto; }

  .mobile-menu {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: min(320px, 85vw);
    background: #FCFAF5;
    display: flex; flex-direction: column;
    padding: 1.5rem 1.25rem;
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
  }
  .mobile-overlay.open .mobile-menu { transform: translateX(0); }

  .mobile-menu-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 2rem; padding-bottom: 1rem;
    border-bottom: 1px solid #e5e2d3;
  }

  .mobile-close {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: #faf8f2; border: none; border-radius: 8px;
    cursor: pointer; color: #515F37; transition: background 0.15s;
  }
  .mobile-close:hover { background: #f0ede3; }
  .mobile-close svg { width: 18px; height: 18px; }

  .mobile-nav {
    display: flex; flex-direction: column; gap: 0.25rem; flex: 1;
  }

  .mobile-link {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 0.875rem 1rem; border-radius: 12px;
    text-decoration: none; color: #374151;
    font-size: 0.95rem; font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }
  .mobile-link svg { width: 20px; height: 20px; flex-shrink: 0; color: #9ca3af; }
  .mobile-link:hover { background: #faf8f2; color: #515F37; }
  .mobile-link:hover svg { color: #515F37; }
  .mobile-link--active { color: #515F37; font-weight: 700; background: rgba(81,95,55,0.07); }
  .mobile-link--active svg { color: #515F37; }

  .mobile-signin {
    display: block; margin-top: 1.5rem; padding: 0.875rem;
    background: #515F37; color: #fff; text-align: center;
    text-decoration: none; border-radius: 12px;
    font-weight: 700; font-size: 0.95rem; transition: background 0.15s;
  }
  .mobile-signin:hover { background: #3d4a28; }

  @media (max-width: 768px) {
    .navbar-links { display: none; }
    .navbar-auth { display: none; }
    .navbar { padding: 0 1.25rem; }
    .burger { display: flex; }
  }
</style>
