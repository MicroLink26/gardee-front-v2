---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path ? 'nav-active' : '';
---
<nav class="navbar">
  <div class="navbar-brand">
    <a href="/">
      <img src="/logo.png" alt="Gardee" height="52" style="display:block;object-fit:contain;" />
    </a>
  </div>
  <ul class="navbar-links">
    <li><a href="/carte" class={isActive('/carte')}>Trouver un jardinier</a></li>
    <li><a href="/classement" class={isActive('/classement')}>Classement</a></li>
    <li><a href="/postuler" class={isActive('/postuler')}>Devenir prestataire</a></li>
    <li><a href="/contact" class={isActive('/contact')}>Contact</a></li>
  </ul>
  <div class="navbar-auth">
    <a href="/app/login" class="btn-outline">Connexion</a>
  </div>
</nav>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 68px;
    background: #d6cda4;
    border-bottom: 1px solid #c4ba8e;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .navbar-links {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  .navbar-links a {
    text-decoration: none;
    color: #374151;
    font-size: 0.95rem;
  }
  .navbar-links a:hover, .nav-active { color: #16a34a; font-weight: 600; }
  .btn-outline {
    padding: 0.4rem 1rem;
    border: 1.5px solid #16a34a;
    border-radius: 6px;
    color: #16a34a;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .btn-outline:hover { background: #16a34a; color: #fff; }
</style>
